#!/usr/bin/env bash
# pair-loop — one-command overnight/interval loop for pair v2.
#
# Encapsulates the efficient-loop recipe so it never has to be done by hand:
#   fresh session        -> each wakeup pays ~8KB fixed context, not your
#                           working session's history (hourly ticks are always
#                           cache-cold, so this is the dominant token lever)
#   cheap model + effort -> execution of a validated plan is sonnet-grade work
#   gate-protected state -> .pair/plan.md (or .claude-loop.md) is re-read every
#                           tick; the stop-gate blocks premature "done"
#   interval wakeups     -> harness timers: no-ops while token quota is
#                           exhausted, automatic continuation when it refreshes
#
# Usage: pair-loop [interval] [--auto] [--model <m>] [--effort <e>] [--pick] [--dry-run]
#   interval   /loop interval (default 1h)
#   --auto     --permission-mode auto: the classifier decides tool calls
#              instantly, so the loop can NEVER stall on a human approval.
#              Default acceptEdits: an unmatched command prompts — and an
#              unattended prompt stalls the loop until you answer it.
#   --model    model (skips the picker; "default" = session default model)
#   --effort   effort level (skips the picker; "default" = session default)
#   --pick     force the interactive model/effort picker (it runs automatically
#              at a TTY when neither flags nor PAIR_LOOP_MODEL/EFFORT are set)
#   --dry-run  print the launch command instead of executing it
#
# Run it in a terminal pane (cmux/tmux) and leave that pane open — the loop
# lives in that session.
set -uo pipefail

INTERVAL="1h"
PERMISSION_MODE="acceptEdits"
MODEL="${PAIR_LOOP_MODEL:-}"
EFFORT="${PAIR_LOOP_EFFORT:-}"
DRY_RUN=0
FORCE_PICK=0
PLAN_OVERRIDE=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --auto) PERMISSION_MODE="auto" ;;
    --model)
      shift
      MODEL="${1:-}"
      ;;
    --effort)
      shift
      EFFORT="${1:-}"
      ;;
    --file)
      shift
      PLAN_OVERRIDE="${1:-}"
      ;;
    --pick) FORCE_PICK=1 ;;
    --dry-run) DRY_RUN=1 ;;
    -*)
      echo "pair-loop: unknown flag $1" >&2
      exit 2
      ;;
    *) INTERVAL="$1" ;;
  esac
  shift
done

# --- Model/effort: yours to pick ----------------------------------------------
# Interactive picker when unset at a TTY (or --pick); scripted callers use
# flags/env. "default" means: don't pass the flag, inherit the session default.
# Accepts the option NUMBER or its NAME (case-insensitive). Never falls back
# silently: unrecognized input re-asks once, then defaults with a visible note.
pick_option() {
  local label="$1" def_idx="$2"
  shift 2
  local opts=("$@") i choice lower attempt
  {
    echo "$label:"
    for i in "${!opts[@]}"; do
      printf '  %d) %s%s\n' "$((i + 1))" "${opts[$i]}" "$([[ $((i + 1)) -eq $def_idx ]] && echo '  (default)')"
    done
  } >&2
  for attempt in 1 2; do
    read -r -p "$label (number or name) [${opts[$((def_idx - 1))]}]: " choice
    [[ -z "$choice" ]] && { echo "${opts[$((def_idx - 1))]}"; return; }
    if [[ "$choice" =~ ^[0-9]+$ ]] && [[ "$choice" -ge 1 && "$choice" -le ${#opts[@]} ]]; then
      echo "${opts[$((choice - 1))]}"
      return
    fi
    lower=$(printf '%s' "$choice" | tr '[:upper:]' '[:lower:]')
    for i in "${!opts[@]}"; do
      if [[ "$lower" == "${opts[$i]}" ]]; then
        echo "${opts[$i]}"
        return
      fi
    done
    echo "  '$choice' is not an option — enter a number 1-${#opts[@]} or a name" >&2
  done
  echo "  using default: ${opts[$((def_idx - 1))]}" >&2
  echo "${opts[$((def_idx - 1))]}"
}

if [[ "$FORCE_PICK" -eq 1 || (-t 0 && -t 1) ]]; then
  [[ -z "$MODEL" ]] && MODEL=$(pick_option "Model" 1 "sonnet" "opus" "haiku" "default")
  [[ -z "$EFFORT" ]] && EFFORT=$(pick_option "Effort" 2 "low" "medium" "high" "default")
  echo "→ model: $MODEL, effort: $EFFORT" >&2
fi
# Non-interactive fallbacks (cron, pipes, --dry-run in tests)
[[ -z "$MODEL" ]] && MODEL="sonnet"
[[ -z "$EFFORT" ]] && EFFORT="medium"

root=$(git rev-parse --show-toplevel 2> /dev/null) || {
  echo "pair-loop: not in a git repository" >&2
  exit 1
}
cd "$root"

# --- Resolve the gate/state file ----------------------------------------------
script_dir=$(cd "$(dirname "$0")" && pwd)
plan_rel="$PLAN_OVERRIDE"

if [[ -z "$plan_rel" && -f .pair/plan.md && -f .claude-loop.md ]]; then
  # Two competing task lists is split-brain — never pick silently.
  echo "pair-loop: BOTH .pair/plan.md and .claude-loop.md exist — refusing to guess." >&2
  echo "pair-loop: a repo should have ONE task list. Either:" >&2
  echo "  pair-loop --file .pair/plan.md      # work the pair plan (usual choice)" >&2
  echo "  pair-loop --file .claude-loop.md    # work the loop file" >&2
  echo "  ...and merge or delete the other to avoid a stale duplicate." >&2
  exit 1
fi

if [[ -z "$plan_rel" ]]; then
  if [[ -f .pair/plan.md ]]; then
    plan_rel=".pair/plan.md"
  elif [[ -f .claude-loop.md ]]; then
    plan_rel=".claude-loop.md"
  else
    echo "pair-loop: no .pair/plan.md or .claude-loop.md found" >&2
    echo "pair-loop: create one with /pair-promote (pair work) or /loop-plan (solo grind)" >&2
    exit 1
  fi
fi

if [[ ! -f "$plan_rel" ]]; then
  echo "pair-loop: $plan_rel does not exist" >&2
  exit 1
fi

# A pair plan must be implementable (TDD-shaped, checkboxes) before looping.
if [[ "$plan_rel" == *".pair/plan.md" ]]; then
  if ! bash "$script_dir/validate-plan.sh" "$root/$plan_rel"; then
    echo "pair-loop: fix the plan first (/pair-promote), then retry" >&2
    exit 1
  fi
fi

unchecked=$(grep -cE '^[[:space:]]*[-*] \[ \]' "$plan_rel" || true)
if [[ "${unchecked:-0}" -eq 0 ]]; then
  echo "pair-loop: no unchecked tasks in $plan_rel — nothing to loop over"
  exit 0
fi

prompt="/loop $INTERVAL work through $plan_rel: re-read it FIRST every wakeup — it is the source of truth, not conversation memory. Do the next unchecked task; TDD order is mandatory (never implement before that task's tests). Mark finished tasks [x] and append one line to a ## Log section (create it if missing). When you complete the last task before a '**Review boundary**' marker (or finish a stream), DO NOT wait for a human: spawn the pair-reviewer agent to review the stream, then work any BLOCKER tasks it appends before moving to the next stream. Once a stream's review is clean, collapse its tasks into one summary line and MOVE their detail to .pair/plan-archive.md — keep this plan lean, it is re-read every wakeup. If blocked on the same task for 2 consecutive wakeups, or an action is denied, write the blocker under the task and move to the next unchecked task — do not retry variations. Never add scope: new ideas go under ## Backlog. Stop only when every box is checked, reviews are clean, and the acceptance criteria hold."

echo "pair-loop: $unchecked task(s) in $plan_rel | interval=$INTERVAL model=$MODEL effort=$EFFORT permissions=$PERMISSION_MODE"
if [[ "$PERMISSION_MODE" == "acceptEdits" ]]; then
  echo "pair-loop: note — an unmatched permission prompt will STALL the loop until answered; use --auto for unattended runs"
fi

cmd=(claude)
[[ "$MODEL" != "default" ]] && cmd+=(--model "$MODEL")
[[ "$EFFORT" != "default" ]] && cmd+=(--effort "$EFFORT")
cmd+=(--permission-mode "$PERMISSION_MODE" "$prompt")

if [[ "$DRY_RUN" -eq 1 ]]; then
  printf '%q ' "${cmd[@]}"
  echo
  echo "(supervised: relaunches while tasks remain, max ${PAIR_LOOP_MAX_RESTARTS:-10} restarts, ${PAIR_LOOP_RESTART_DELAY:-30}s delay)"
  exit 0
fi

# --- Supervision loop ----------------------------------------------------------
# The /loop wakeups live inside the claude session — if the session dies
# (crash, quota-forced exit, accidental /exit) the whole night is lost. State
# lives in the plan file, so a fresh session resumes losslessly (gate-orient
# injects the plan status on SessionStart). Relaunching also recycles context:
# each new session starts cheap instead of dragging the previous ticks.
#
# Ctrl-C handling: while claude runs, the supervisor ignores INT so ^C only
# reaches claude (normal interactive use). Between sessions, ^C kills the
# supervisor during the relaunch countdown.
max_restarts="${PAIR_LOOP_MAX_RESTARTS:-10}"
delay="${PAIR_LOOP_RESTART_DELAY:-30}"
run=0

# macOS notification via the shared hook script — an overnight loop must not
# end silently, whether it finished or gave up.
notify_user() {
  printf '{"message":"%s","cwd":"%s"}' "$1" "$root" \
    | bash "$script_dir/../../../hooks/await-notify.sh" 2> /dev/null || true
}

while :; do
  run=$((run + 1))
  trap '' INT
  "${cmd[@]}"
  code=$?
  trap - INT

  open=$(grep -cE '^[[:space:]]*[-*] \[ \]' "$plan_rel" 2> /dev/null || true)
  if [[ "${open:-0}" -eq 0 ]]; then
    echo "pair-loop: all tasks checked — loop complete after $run session(s)"
    notify_user "pair-loop COMPLETE: all tasks checked after $run session(s)"
    exit 0
  fi
  if [[ "$run" -gt "$max_restarts" ]]; then
    echo "pair-loop: session ended (exit $code) with $open task(s) still open, but max restarts ($max_restarts) reached — inspect the ## Log in $plan_rel" >&2
    notify_user "pair-loop GAVE UP: $open task(s) open after $max_restarts restarts — check the Log"
    exit 1
  fi
  echo "pair-loop: session ended (exit $code) with $open task(s) still open — relaunching fresh in ${delay}s (Ctrl-C now to stop)"
  sleep "$delay" || exit 130
done
