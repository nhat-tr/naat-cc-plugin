#!/usr/bin/env bash
# workflow-metrics — measure agent-workflow friction from Claude Code session
# JSONLs. Run before/after a workflow change to get evidence instead of vibes.
#
# Metrics: user interrupts, "continue" nudges, tool rejections, permission-mode
# mix, raw /tmp usage, scratch-dir usage, context compactions, stop-gate blocks,
# pair-review runs.
#
# Usage:
#   workflow-metrics                 # sessions modified in the last 14 days
#   workflow-metrics --days 7
#   workflow-metrics file1.jsonl ... # explicit session files
set -uo pipefail

DAYS=14
FILES=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --days)
      shift
      DAYS="${1:-14}"
      ;;
    *) FILES+=("$1") ;;
  esac
  shift
done

if [[ ${#FILES[@]} -eq 0 ]]; then
  while IFS= read -r f; do FILES+=("$f"); done < <(
    find "$HOME/.claude/projects" -maxdepth 2 -name '*.jsonl' -type f -mtime "-$DAYS" 2> /dev/null | grep -v '/subagents/'
  )
fi
if [[ ${#FILES[@]} -eq 0 ]]; then
  echo "workflow-metrics: no session files found"
  exit 1
fi

command -v jq > /dev/null || {
  echo "workflow-metrics: jq required" >&2
  exit 1
}

total_lines=0 interrupts=0 nudges=0 rejections=0 tmp_refs=0 scratch_refs=0
compactions=0 gate_blocks=0 reviews=0 mode_default=0 mode_accept=0 mode_bypass=0 mode_plan=0
delegations=0 manual_edits=0 delegation_nudges=0

for f in "${FILES[@]}"; do
  [[ -s "$f" ]] || continue
  lines=$(wc -l < "$f" | tr -d ' ')
  total_lines=$((total_lines + lines))

  # Interrupts arrive as array content [{type:"text",text:"[Request interrupted..."}];
  # typed nudges are plain-string content (keeps /loop-injected prompts out of the count).
  read -r i n < <(jq -rs '
    [([.[] | select(.type == "user") | .message.content | select(type == "array")
       | .[] | select(.type? == "text") | .text | select(startswith("[Request interrupted"))] | length),
     ([.[] | select(.type == "user") | .message.content | select(type == "string")
       | select(test("^\\s*(continue|resume|keep going|proceed|finish|go on)\\b"; "i"))] | length)]
    | @tsv' "$f" 2> /dev/null || echo "0	0")
  interrupts=$((interrupts + ${i:-0}))
  nudges=$((nudges + ${n:-0}))

  # Delegation rate: subagent spawns vs main-session hand edits
  read -r dg me < <(jq -rs '
    [([.[] | select(.type == "assistant") | .message.content[]? | select(.type == "tool_use" and .name == "Agent")] | length),
     ([.[] | select(.type == "assistant") | .message.content[]? | select(.type == "tool_use" and (.name == "Edit" or .name == "Write" or .name == "MultiEdit"))] | length)]
    | @tsv' "$f" 2> /dev/null || echo "0	0")
  delegations=$((delegations + ${dg:-0}))
  manual_edits=$((manual_edits + ${me:-0}))
  delegation_nudges=$((delegation_nudges + $(grep -c "Delegation check:" "$f" 2> /dev/null || true)))

  rejections=$((rejections + $(grep -c "user doesn't want to proceed" "$f" 2> /dev/null || true)))
  compactions=$((compactions + $(grep -c "continued from a previous conversation" "$f" 2> /dev/null || true)))
  gate_blocks=$((gate_blocks + $(grep -c '"Stop gate (' "$f" 2> /dev/null || true)))
  reviews=$((reviews + $(grep -c "pair-review: verdict" "$f" 2> /dev/null || true)))

  # Raw system-/tmp use in tool inputs, excluding the harness scratchpad/tasks
  t=$(jq -rs '[.[] | select(.type == "assistant") | .message.content[]? | select(.type == "tool_use") | .input | tostring
       | select(test("/tmp/")) | select(test("tmp/claude-") | not)] | length' "$f" 2> /dev/null || echo 0)
  tmp_refs=$((tmp_refs + ${t:-0}))
  s=$(jq -rs '[.[] | select(.type == "assistant") | .message.content[]? | select(.type == "tool_use") | .input | tostring
       | select(test("\\.claude-scratch"))] | length' "$f" 2> /dev/null || echo 0)
  scratch_refs=$((scratch_refs + ${s:-0}))

  # Permission-mode message mix
  read -r md ma mb mp < <(jq -rs '
    [.[] | select(.type == "permission-mode") | .permissionMode] as $m
    | [([$m[] | select(. == "default" or . == "auto")] | length),
       ([$m[] | select(. == "acceptEdits")] | length),
       ([$m[] | select(. == "bypassPermissions")] | length),
       ([$m[] | select(. == "plan")] | length)] | @tsv' "$f" 2> /dev/null || echo "0	0	0	0")
  mode_default=$((mode_default + ${md:-0}))
  mode_accept=$((mode_accept + ${ma:-0}))
  mode_bypass=$((mode_bypass + ${mb:-0}))
  mode_plan=$((mode_plan + ${mp:-0}))
done

mode_total=$((mode_default + mode_accept + mode_bypass + mode_plan))
elevated_pct="n/a"
if [[ "$mode_total" -gt 0 ]]; then
  elevated_pct=$(((mode_accept + mode_bypass) * 100 / mode_total))%
fi

cat <<EOF
workflow-metrics — ${#FILES[@]} session(s), $total_lines lines
  user interrupts             $interrupts
  continue/keep-going nudges  $nudges
  tool rejections             $rejections
  context compactions         $compactions
  raw /tmp tool refs          $tmp_refs
  scratch-dir tool refs       $scratch_refs
  stop-gate blocks            $gate_blocks
  pair-review runs            $reviews
  subagent delegations        $delegations
  main-session edits          $manual_edits
  delegation nudges fired     $delegation_nudges
  permission modes            default=$mode_default acceptEdits=$mode_accept bypass=$mode_bypass plan=$mode_plan (elevated: $elevated_pct)
EOF
