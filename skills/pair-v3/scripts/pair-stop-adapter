#!/usr/bin/env node

const childProcess = require('node:child_process');
const fs = require('node:fs');
const path = require('node:path');

const { loadPairState } = require('./lib/pair-state');
const { recordAgentConversationStop } = require('./lib/handover-state');

function readInput() {
  try {
    return JSON.parse(fs.readFileSync(0, 'utf8') || '{}');
  } catch {
    return null;
  }
}

function repositoryRoot(cwd) {
  const result = childProcess.spawnSync('git', ['rev-parse', '--show-toplevel'], {
    cwd,
    encoding: 'utf8',
  });
  return result.status === 0 ? result.stdout.trim() : null;
}

function runtimeFor(input) {
  const configured = String(process.env.PAIR_HOOK_RUNTIME || input?.runtime || '').toLowerCase();
  if (configured === 'codex' || configured === 'claude') return configured;
  if (process.env.CLAUDE_PROJECT_DIR || process.env.CLAUDECODE) return 'claude';
  return 'codex';
}

function continuationReason(state) {
  const active = state.active;
  if (active) {
    return `Pair v4 continuation owns this chat: resume attempt ${active.attempt_id} for task ${active.task_id} at ${active.phase}. Evidence sequence ${state.sequence}. Run pair-loop --status, preserve the current patch, and continue the exact saved phase.`;
  }
  return `Pair v4 continuation owns this chat: Work ${state.work_id} remains ${state.lifecycle}. Evidence sequence ${state.sequence}. Run pair-loop --status and advance the next actionable phase.`;
}

function response(runtime, reason) {
  return { decision: 'block', reason };
}

function hardStopResponse(reason) {
  return { continue: false, stopReason: reason };
}

function continuationResponse(root, input, runtime = runtimeFor(input)) {
  const pairDirectory = path.join(root, '.pair');
  const hasAuthority = [
    path.join(pairDirectory, 'events.jsonl'),
    path.join(pairDirectory, 'current-run.json'),
    path.join(pairDirectory, 'runs'),
  ].some(candidate => fs.existsSync(candidate));
  if (!hasAuthority) return null;
  let state;
  try {
    state = loadPairState(root);
  } catch {
    return null;
  }
  const owner = state.continuation?.owner_session_id;
  if (!owner || !input.session_id || owner !== input.session_id) return null;
  if (
    state.continuation.paused ||
    state.continuation.human_edit ||
    ['idle', 'paused', 'blocked', 'complete'].includes(state.lifecycle)
  ) return null;
  return response(runtime, continuationReason(state));
}

function main() {
  if (process.env.PAIR_STOP_GATE === 'off' || process.env.CLAUDE_STOP_GATE === 'off') return;
  const input = readInput();
  if (!input || input.hook_event_name !== 'Stop' || !String(input.session_id || '').trim()) return;
  const cwd = input.cwd || input.project_dir || process.env.CLAUDE_PROJECT_DIR || process.cwd();
  const root = repositoryRoot(cwd);
  if (!root) return;
  const runtime = runtimeFor(input);
  let recorded;
  try {
    recorded = recordAgentConversationStop(root, {
      runtime,
      agentConversationId: input.session_id,
      kind: input.agent_conversation_kind || 'pair',
      now: input.now,
    });
  } catch (error) {
    const checkpointFailure = /checkpoint|not consumed/iu.test(error.message || '');
    const reason = checkpointFailure
      ? 'Freshness Gate stopped this turn without scheduling another old-conversation prompt: refresh the Agent Conversation Checkpoint during the one authorized turn before Stop.'
      : 'Freshness Gate stopped this registered Agent Conversation because its handover state is invalid.';
    process.stdout.write(`${JSON.stringify(hardStopResponse(reason))}\n`);
    return;
  }
  if (['sealed', 'retired', 'override-active', 'override-consumed'].includes(recorded.status)) return;
  const continuation = continuationResponse(root, input, runtime);
  if (continuation) process.stdout.write(`${JSON.stringify(continuation)}\n`);
}

if (require.main === module) main();

module.exports = {
  continuationReason,
  continuationResponse,
  hardStopResponse,
  response,
  runtimeFor,
};
