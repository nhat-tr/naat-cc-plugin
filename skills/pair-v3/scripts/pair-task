function isPairRuntimeArtifact(file) {
  const normalized = file.split(path.sep).join("/");
  return PAIR_ATTEMPT_MARKERS.has(normalized) ||
    normalized === ".pair/events.jsonl" ||
    normalized === ".pair/state.json" ||
    normalized === ".pair/status.md" ||
    normalized === ".pair/current-run.json" ||
    normalized === ".pair/ledger-bindings.json" ||
    normalized === ".pair/review.json" ||
    normalized === ".pair/review.md" ||
    normalized === ".pair/final-review.json" ||
    normalized === ".pair/final-review.md" ||
    normalized === ".pair/test-proposal.json" ||
    normalized === ".pair/tmux.json" ||
    normalized === ".pair/review-session.json" ||
    normalized.startsWith(".pair/attempts/") ||
    normalized.startsWith(".pair/runs/") ||
    normalized.startsWith(".pair/plan-reviews/");
}

function fail(message) {
  console.error(`pair-task: ${message}`);
  process.exit(1);
}

function parseArgs(argv) {
  const options = {
    runtime: process.env.PAIR_RUNTIME || "auto",
    once: false,
    dryRun: false,
    hitl: process.env.PAIR_HITL === "1",
    maxAttempts: process.env.PAIR_MAX_TASK_ATTEMPTS
      ? Number(process.env.PAIR_MAX_TASK_ATTEMPTS)
      : null,
    maxWorkAttempts: process.env.PAIR_MAX_WORK_ATTEMPTS
      ? Number(process.env.PAIR_MAX_WORK_ATTEMPTS)
      : null,
    maxFinalReviews: process.env.PAIR_MAX_FINAL_REVIEWS
      ? Number(process.env.PAIR_MAX_FINAL_REVIEWS)
      : null,
    legacyV3: process.env.PAIR_LEGACY_V3 === "1",
    independentReview: process.env.PAIR_INDEPENDENT_REVIEW !== "off",
    advisoryReview: process.env.PAIR_REVIEW_MODE === "advisory",
    freshFrom: null,
    adoptHandover: null,
    allowColdResume: null,
    confirmCostRisk: false,
    allowCrossRuntimeFallback:
      process.env.PAIR_ALLOW_CROSS_RUNTIME_FALLBACK === "1",
    control: null,
    json: false,
  };
  for (let index = 0; index < argv.length; index++) {
    const arg = argv[index];
    if (arg === "--runtime") options.runtime = argv[++index];
    else if (arg === "--fresh-from") options.freshFrom = argv[++index];
    else if (arg === "--adopt-handover") options.adoptHandover = argv[++index];
    else if (arg === "--allow-cold-resume") options.allowColdResume = argv[++index];
    else if (arg === "--confirm-cost-risk") options.confirmCostRisk = true;
    else if (arg === "--model") options.model = argv[++index];
    else if (arg === "--effort") options.effort = argv[++index];
    else if (arg === "--once") options.once = true;
    else if (arg === "--dry-run") options.dryRun = true;
    else if (arg === "--inline") options.inline = true;
    else if (arg === "--complete") options.complete = true;
    else if (arg === "--doctor") options.doctor = true;
    else if (["--host", "--attach", "--status", "--pause", "--resume", "--cancel-now", "--end-human-edit"].includes(arg))
      options.control = arg.slice(2);
    else if (arg === "--discard-attempt") {
      options.control = "discard-attempt";
      options.controlValue = argv[index + 1] && !argv[index + 1].startsWith("-")
        ? argv[++index]
        : null;
    } else if (arg === "--confirm-discard") options.confirmDiscard = true;
    else if (arg === "--takeover") {
      options.control = "takeover";
      options.controlValue = argv[index + 1] && !argv[index + 1].startsWith("-")
        ? argv[++index]
        : null;
    } else if (arg === "--begin-human-edit") {
      options.control = "begin-human-edit";
      options.controlValue = argv[++index];
    } else if (arg === "--steer") {
      options.control = "steer";
      options.controlValue = argv[++index];
    } else if (arg === "--json") options.json = true;
    else if (arg === "--legacy-v3") options.legacyV3 = true;
    else if (["--no-independent-review", "--no-review"].includes(arg)) options.independentReview = false;
    else if (arg === "--advisory-review") options.advisoryReview = true;
    else if (arg === "--allow-cross-runtime-fallback")
      options.allowCrossRuntimeFallback = true;
    else if (arg === "--hitl") options.hitl = true;
    else if (arg === "--approve-tests") {
      options.approveTests =
        argv[index + 1] && !argv[index + 1].startsWith("-")
          ? argv[++index]
          : "all";
    } else if (arg === "--max-attempts")
      options.maxAttempts = Number(argv[++index]);
    else if (arg === "--max-work-attempts")
      options.maxWorkAttempts = Number(argv[++index]);
    else if (arg === "--max-final-reviews")
      options.maxFinalReviews = Number(argv[++index]);
    else if (arg === "--help") options.help = true;
    else fail(`unknown option ${arg}`);
  }
  if (!Number.isFinite(options.maxAttempts)) {
    options.maxAttempts = options.legacyV3 ? 3 : null;
  }
  return options;
}

function git(root, args, options = {}) {
  return childProcess.spawnSync("git", args, {
    cwd: root,
    encoding: "utf8",
    ...options,
  });
}

function gitRoot() {
  const result = childProcess.spawnSync(
    "git",
    ["rev-parse", "--show-toplevel"],
    { encoding: "utf8" },
  );
  if (result.status !== 0) fail("not in a git repository");
  return result.stdout.trim();
}

function readJson(file, fallback = null) {
  try {
    return JSON.parse(fs.readFileSync(file, "utf8"));
  } catch {
    return fallback;
  }
}

function writePrivateJson(file, value) {
  fs.mkdirSync(path.dirname(file), { recursive: true, mode: 0o700 });
  fs.writeFileSync(
    file,
    `${JSON.stringify(sanitizeValue(value), null, 2)}\n`,
    { mode: 0o600 },
  );
}

function processAlive(pid) {
  if (!Number.isInteger(pid) || pid <= 0) return false;
  try {
    process.kill(pid, 0);
    return true;
  } catch {
    return false;
  }
}

function liveInFlightRequest(state) {
  const request = state?.in_flight_request;
  // The journal, not a best-effort PID probe, owns request liveness. Sandboxed
  // coordinators can be unable to signal a visible reviewer process even while
  // it is running; only request.completed/request.cancelled may release it.
  return request || null;
}

function beginActivePairLoop(root, plan) {
  const markerFile = path.join(root, ".pair", "active-loop.json");
  const existing = readJson(markerFile);
  if (existing?.pid && processAlive(existing.pid)) {
    throw new Error(`Pair Loop is already active in process ${existing.pid}`);
  }
  fs.rmSync(markerFile, { force: true });
  const marker = {
    schema: 1,
    run_id: crypto.randomUUID(),
    pid: process.pid,
    plan: path.relative(root, plan).split(path.sep).join("/"),
    started_at: new Date().toISOString(),
  };
  fs.writeFileSync(markerFile, `${JSON.stringify(marker, null, 2)}\n`, {
    flag: "wx",
    mode: 0o600,
  });
  return marker;
}

function endActivePairLoop(root, marker) {
  const markerFile = path.join(root, ".pair", "active-loop.json");
  const current = readJson(markerFile);
  if (current?.run_id === marker?.run_id)
    fs.rmSync(markerFile, { force: true });
}

function sha256(value) {
  return crypto.createHash("sha256").update(value).digest("hex");
}

function readWorkIdentity(root, plan) {
  const planStateDigest = sha256(plan);
  const contractDigest = planContractDigest(plan);
  const mirrorFile = path.join(root, ".pair", "spec.md");
  if (!fs.existsSync(mirrorFile)) {
    return {
      work: null,
      workId: null,
      specDigest: null,
      planDigest: contractDigest,
      planStateDigest,
      decisionRecordIds: [],
    };
  }
  const mirror = fs.readFileSync(mirrorFile, "utf8");
  const canonicalPath = mirror.match(/^Canonical: (.+)$/m)?.[1];
  const specDigest = mirror.match(/^Canonical SHA-256: ([a-f0-9]{64})$/m)?.[1];
  if (!canonicalPath || !specDigest)
    throw new Error("active pair spec is not a canonical digest-linked mirror");
  const resolvedRoot = fs.realpathSync(root);
  const canonicalFile = path.resolve(resolvedRoot, canonicalPath);
  if (
    canonicalFile !== resolvedRoot &&
    !canonicalFile.startsWith(`${resolvedRoot}${path.sep}`)
  ) {
    throw new Error("canonical spec path escapes the repository root");
  }
  if (!fs.existsSync(canonicalFile))
    throw new Error(`canonical spec does not exist: ${canonicalPath}`);
  const realCanonicalFile = fs.realpathSync(canonicalFile);
  if (!realCanonicalFile.startsWith(`${resolvedRoot}${path.sep}`)) {
    throw new Error("canonical spec resolves outside the repository root");
  }
  const spec = fs.readFileSync(realCanonicalFile, "utf8");
  if (sha256(spec) !== specDigest)
    throw new Error("canonical spec digest does not match active pair mirror");
  const expectedMirror = [
    "<!-- GENERATED ACTIVE MIRROR",
    `Canonical: ${canonicalPath}`,
    `Canonical SHA-256: ${specDigest}`,
    "-->",
    spec,
  ].join("\n");
  if (mirror !== expectedMirror)
    throw new Error("active pair mirror bytes do not match the canonical spec");
  const workDirectory = path.dirname(realCanonicalFile);
  const work = validateWorkDirectory(workDirectory);
  const expectedCanonicalPath = `docs/work/${work.work_id}/spec.md`;
  if (
    workDirectory !== path.join(resolvedRoot, "docs", "work", work.work_id) ||
    canonicalPath !== expectedCanonicalPath
  ) {
    throw new Error("canonical Work index is not stored at its Work ID path");
  }
  if (
    !work ||
    work.spec?.path !== canonicalPath ||
    work.spec?.sha256 !== specDigest ||
    !work.work_id
  ) {
    throw new Error(
      "canonical Work index does not match the active pair mirror",
    );
  }
  const decisionRecordIds = (work.decision_records || [])
    .map((reference) => path.basename(reference, ".md"))
    .sort();
  return {
    work,
    workId: work.work_id,
    specDigest,
    planDigest: contractDigest,
    planStateDigest,
    decisionRecordIds,
  };
}

function readWorkLinkage(root, plan) {
  const { work, ...identity } = readWorkIdentity(root, plan);
  if (!work) return identity;
  const contractDigest = identity.planDigest;
  if (work.plan && work.plan.sha256 !== contractDigest) {
    throw new Error(
      "approved Pair plan digest does not match the current plan contract",
    );
  }
  if (!work.plan) {
    throw new Error(
      "approved Pair plan is missing an independent challenge or explicit human override bound to its current contract digest",
    );
  }
  const review = String(work.plan.independent_review || "");
  const independentlyApproved = new RegExp(
    `^no-blockers:${contractDigest}:(?:codex|claude)/[^\\s:]+$`,
  ).test(review);
  const manuallyApproved = new RegExp(
    `^human-override:${contractDigest}:user:[a-f0-9]{12}$`,
  ).test(review);
  if (!independentlyApproved && !manuallyApproved) {
    throw new Error(
      "approved Pair plan is missing an independent challenge or explicit human override bound to its current contract digest",
    );
  }
  return { ...identity, planDigest: work.plan.sha256 };
}

function planNeedsApproval(error) {
  return /approved Pair plan digest does not match|missing an independent challenge or explicit human override/i
    .test(String(error?.message || error));
}

function ensurePairPlanApproval(root, plan, options) {
  try {
    return readWorkLinkage(root, plan);
  } catch (error) {
    if (
      !planNeedsApproval(error) ||
      options.dryRun ||
      process.env.PAIR_AUTO_PLAN_CHALLENGE === "0"
    ) {
      throw error;
    }
  }

  console.log(
    "pair-loop: current plan digest is not approved; running the bounded plan challenge",
  );
  const args = [
    path.join(SCRIPT_DIR, "pair-plan-challenge"),
    "--runtime",
    options.runtime,
  ];
  if (options.allowCrossRuntimeFallback) {
    args.push("--allow-cross-runtime-fallback");
  }
  if (options.model) args.push("--model", options.model);
  if (options.effort) args.push("--effort", options.effort);
  const challenge = childProcess.spawnSync(process.execPath, args, {
    cwd: root,
    stdio: "inherit",
    env: process.env,
  });
  if (challenge.status !== 0) {
    console.error(
      `pair-task: automatic plan challenge did not approve the current digest (status ${challenge.status ?? "unknown"})`,
    );
    process.exit(Number.isInteger(challenge.status) ? challenge.status : 1);
  }
  return readWorkLinkage(root, plan);
}

function readLedger(file) {
  const normalized = path.resolve(file).split(path.sep).join("/");
  const pairMarker = "/.pair/";
  if (path.basename(file) === "events.jsonl" && normalized.includes(pairMarker)) {
    const root = normalized.slice(0, normalized.indexOf(pairMarker));
    const workId = normalized.match(/\/\.pair\/runs\/([^/]+)\/events\.jsonl$/u)?.[1];
    return readPairEvents(root, workId);
  }
  if (!fs.existsSync(file)) return [];
  return fs
    .readFileSync(file, "utf8")
    .split(/\r?\n/)
    .filter(Boolean)
    .map((line) => {
      try {
        return JSON.parse(line);
      } catch {
        return null;
      }
    })
    .filter(Boolean);
}

function appendJsonLine(file, value) {
  const normalized = path.resolve(file).split(path.sep).join("/");
  const pairMarker = "/.pair/";
  if (path.basename(file) === "events.jsonl" && normalized.includes(pairMarker)) {
    const root = normalized.slice(0, normalized.indexOf(pairMarker));
    return appendPairEvent(root, value);
  }
  fs.mkdirSync(path.dirname(file), { recursive: true });
  fs.appendFileSync(file, `${JSON.stringify(value)}\n`, { mode: 0o600 });
}

// The set of task IDs already checked off in the plan. Used to tell a genuinely
// interrupted attempt (retry it) from one whose task was completed out of band —
// e.g. the coordinator did the work via a delegated subagent and checked the box —
// which must be recorded as accepted, not retried. Empty on any parse failure.
function checkedTaskIds(planPath) {
  try {
    if (!planPath || !fs.existsSync(planPath)) return new Set();
    return new Set(
      parsePlan(fs.readFileSync(planPath, "utf8"))
        .tasks.filter((task) => task.checked)
        .map((task) => task.id),
    );
  } catch {
    return new Set();
  }
}

// Build the completion record for a dangling attempt. If its task is already checked
// off, the work happened outside the loop: record it accepted (out of band). Otherwise
// it was interrupted and should be retried. Either way it is marked invalid so it never
// trains routing on an outcome the loop did not itself measure.
function orphanCompletion(envelope, checkedIds) {
  const doneOutOfBand = Boolean(
    envelope.taskId && checkedIds.has(envelope.taskId),
  );
  return {
    event: "attempt.completed",
    ...envelope,
    status: doneOutOfBand ? "completed-out-of-band" : "interrupted",
    finishedAt: new Date().toISOString(),
    disposition: doneOutOfBand ? "accepted" : "regenerated",
    action: doneOutOfBand ? "complete-task" : "retry-infrastructure",
    cause: doneOutOfBand ? null : "environment-failure",
    success: doneOutOfBand,
    valid: false,
    totalCost: null,
    costSource: "unknown",
  };
}

function recoverActiveAttempt(paths) {
  if (!fs.existsSync(paths.active)) return false;
  const active = readJson(paths.active);
  if (!active?.attemptId) {
    fs.rmSync(paths.active, { force: true });
    return false;
  }
  const alreadyCompleted = readLedger(paths.ledger).some(
    (record) =>
      ["attempt.completed", "attempt.outcome"].includes(record.event) &&
      record.attemptId === active.attemptId &&
      record.terminal !== false,
  );
  const completion = orphanCompletion(active, checkedTaskIds(paths.plan));
  if (alreadyCompleted) {
    fs.rmSync(paths.active, { force: true });
    return false;
  }
  if (completion.status === "completed-out-of-band") {
    appendJsonLine(paths.ledger, completion);
    fs.rmSync(paths.active, { force: true });
    console.log(
      `pair-v4: attempt ${active.attemptId} task ${active.taskId} was completed outside Pair; recorded as accepted`,
    );
    return true;
  }

  const phase = active.phase || "implementing";
  const recovered = { ...active, phase, resume_target: phase };
  writePrivateJson(paths.active, recovered);
  appendJsonLine(paths.ledger, {
    event: "attempt.recovered",
    attemptId: active.attemptId,
    taskId: active.taskId,
    workId: active.workId || null,
    planDigest: active.planDigest || null,
    phase,
    resume_target: phase,
    sessionId: active.sessionId || null,
  });
  console.log(`pair-v4: resuming attempt ${active.attemptId} at ${phase}`);
  return true;
}

// Close any attempt.started record for THIS working root that never got a matching
// attempt.completed. A hard interrupt (crash, kill, sleep) or a manual .pair reset
// strands starts in the shared global ledger; left dangling they make the safety cap and
// pair-report under-count real runs. recoverActiveAttempt handles the single live
// active-attempt.json; this heals every other orphan the ledger still carries. Scoped by
// the absolute repo root (not repositoryId, which is shared across worktrees/clones of the
// same origin) so a run in a sibling worktree with a live in-flight attempt is never
// mistaken for an orphan. Records predating root stamping (no root field) are left alone.
function reconcileOrphanedAttempts(paths, root) {
  const ledger = readLedger(paths.ledger);
  const completed = new Set(
    ledger
      .filter((record) => record.event === "attempt.completed")
      .map((record) => record.attemptId),
  );
  const checkedIds = checkedTaskIds(paths.plan);
  const seen = new Set();
  let closed = 0;
  for (const record of ledger) {
    if (record.event !== "attempt.started" || !record.attemptId) continue;
    if (record.root !== root) continue;
    if (completed.has(record.attemptId) || seen.has(record.attemptId)) continue;
    seen.add(record.attemptId);
    const { event, status, ...envelope } = record;
    appendJsonLine(paths.ledger, orphanCompletion(envelope, checkedIds));
    closed++;
  }
  if (closed > 0)
    console.log(
      `pair-loop: reconciled ${closed} dangling attempt(s) stranded by a prior run`,
    );
  return closed;
}

function routesFor(runtime) {
  if (runtime === "claude") {
    return [
      {
        id: "claude-haiku-low",
        runtime,
        model: process.env.PAIR_CLAUDE_LOW_MODEL || "haiku",
        effort: "low",
        strength: 1,
        expectedCost: 0.05,
      },
      {
        id: "claude-sonnet-medium",
        runtime,
        model: process.env.PAIR_CLAUDE_MEDIUM_MODEL || "sonnet",
        effort: "medium",
        strength: 2,
        expectedCost: 0.25,
      },
      {
        id: "claude-opus-high",
        runtime,
        model: process.env.PAIR_CLAUDE_HIGH_MODEL || "opus",
        effort: "high",
        strength: 3,
        expectedCost: 0.8,
      },
      {
        id: "claude-opus-max",
        runtime,
        model: process.env.PAIR_CLAUDE_CRITICAL_MODEL || "opus",
        effort: "max",
        strength: 4,
        expectedCost: 1.2,
      },
    ];
  }
  return [
    {
      id: "codex-default-low",
      runtime,
      model: process.env.PAIR_CODEX_LOW_MODEL || "gpt-5.5",
      effort: "low",
      strength: 1,
      expectedCost: 0.1,
    },
    {
      id: "codex-default-medium",
      runtime,
      model: process.env.PAIR_CODEX_MEDIUM_MODEL || "gpt-5.5",
      effort: "medium",
      strength: 2,
      expectedCost: 0.3,
    },
    {
      id: "codex-default-high",
      runtime,
      model: process.env.PAIR_CODEX_HIGH_MODEL || "gpt-5.5",
      effort: "high",
      strength: 3,
      expectedCost: 0.7,
    },
    {
      id: "codex-default-xhigh",
      runtime,
      model: process.env.PAIR_CODEX_CRITICAL_MODEL || "gpt-5.5",
      effort: "xhigh",
      strength: 4,
      expectedCost: 1.0,
    },
  ];
}

function taskHistory(ledger, taskId, repoId, workId = null, planDigest = null) {
  const seenAttemptIds = new Set();
  return ledger.filter((record) => {
    const matches =
      record.taskId === taskId &&
      record.event === "attempt.completed" &&
      (!repoId || record.repositoryId === repoId) &&
      (!workId || record.workId === workId) &&
      (!planDigest || record.planDigest === planDigest);
    if (!matches || !record.attemptId) return matches;
    if (seenAttemptIds.has(record.attemptId)) return false;
    seenAttemptIds.add(record.attemptId);
    return true;
  });
}

function workAttemptCapStatus(ledger, repoId, workId, maxAttempts) {
  const seenAttemptIds = new Set();
  const attempts = ledger.filter((record) => {
    const substantive =
      record.event === "attempt.completed" &&
      record.repositoryId === repoId &&
      record.workId === workId &&
      !["interrupted", "completed-out-of-band"].includes(record.status);
    if (!substantive || !record.attemptId) return substantive;
    if (seenAttemptIds.has(record.attemptId)) return false;
    seenAttemptIds.add(record.attemptId);
    return true;
  }).length;
  return { attempts, maxAttempts, overCap: attempts >= maxAttempts };
}

function finalReviewCapStatus(ledger, repoId, workId, maxReviews) {
  const reviews = ledger.filter((record) =>
    record.event === "final-review.completed" &&
    record.repositoryId === repoId &&
    record.workId === workId,
  ).length;
  return { reviews, maxReviews, overCap: reviews >= maxReviews };
}

function finalGateFailureCapStatus(ledger, repoId, workId, maxFailures) {
  const failures = ledger.filter((record) =>
    record.event === "final-gate.completed" &&
    record.repositoryId === repoId &&
    record.workId === workId &&
    record.status === "fail",
  ).length;
  return { failures, maxFailures, overCap: failures >= maxFailures };
}

function repositoryId(root) {
  const remote = git(root, ["config", "--get", "remote.origin.url"]);
  const identity =
    remote.status === 0 && remote.stdout.trim() ? remote.stdout.trim() : root;
  return require("node:crypto")
    .createHash("sha256")
    .update(identity)
    .digest("hex")
    .slice(0, 16);
}

function bindAttemptLedger(root, ledgerFile, workId = null, planPath = ".pair/plan.md") {
  const bindingFile = path.join(root, ".pair", "ledger-bindings.json");
  const state = readJson(bindingFile, { schema: 2, authority: "repository", bindings: {} });
  if (![1, 2].includes(state?.schema) || !state.bindings || typeof state.bindings !== "object") {
    throw new Error(".pair/ledger-bindings.json is malformed");
  }
  const key = workId
    ? `work:${workId}`
    : `repository:${repositoryId(root)}:${path.relative(root, planPath).split(path.sep).join("/")}`;
  const ledger = pairStatePaths(root, workId).events;
  const legacyLedger = ledgerFile ? path.resolve(ledgerFile) : null;
  const existing = state.bindings[key];
  const legacySource = existing?.legacy_ledger ||
    (existing?.ledger && path.resolve(existing.ledger) !== path.resolve(ledger)
      ? existing.ledger
      : legacyLedger);
  if (legacySource && path.resolve(legacySource) !== path.resolve(ledger)) {
    importLegacyAttemptHistory(root, legacySource, workId);
  }
  state.schema = 2;
  state.authority = "repository";
  state.bindings[key] = {
    ledger: path.relative(root, ledger).split(path.sep).join("/"),
    legacy_ledger: legacySource || null,
    bound_at: existing?.bound_at || new Date().toISOString(),
  };
  fs.writeFileSync(bindingFile, `${JSON.stringify(state, null, 2)}\n`, {
    mode: 0o600,
  });
  return state.bindings[key];
}

function chooseRoute(task, runtime, ledger, options, repoId, workId = null, planDigest = null) {
  const routes = routesFor(runtime);
  if (options.model || options.effort) {
    return {
      id: `${runtime}-${options.model || "default"}-${options.effort || "default"}`,
      runtime,
      model: options.model || "default",
      effort: options.effort || "default",
      strength: 4,
    };
  }
  const prior = taskHistory(ledger, task.id, repoId, workId, planDigest);
  const last = prior.findLast((record) => record.status !== "interrupted");
  const strongest = routes.at(-1);
  const spent = prior.reduce((sum, attempt) => {
    if (Number.isFinite(attempt.totalCost)) return sum + attempt.totalCost;
    return attempt.valid
      ? sum +
          (routes.find((route) => route.id === attempt.routeId)?.expectedCost ||
            0)
      : sum;
  }, 0);
  if (spent >= strongest.expectedCost) return strongest;
  if (last?.action === "escalate" || last?.action === "retry-stronger") {
    // An unknown prior route (e.g. an inline-coordinator attempt) escalates straight
    // to the strongest configured route rather than restarting the ladder.
    const current = routes.find((route) => route.id === last.routeId);
    return (
      routes.find(
        (route) => route.strength > (current?.strength ?? strongest.strength),
      ) || strongest
    );
  }
  if (["retry-infrastructure", "retry-ownership", "retry-verification", "retry-review"].includes(last?.action))
    return (
      routes.find((route) => route.id === last.routeId) ||
      selectRoute(task, routes)
    );
  if (last?.action === "retry-context") {
    const current = routes.find((route) => route.id === last.routeId);
    return (
      routes.find((route) => route.strength > (current?.strength || 1)) ||
      strongest
    );
  }
  if (last?.action === "local-fix")
    return (
      routes.find((route) => route.id === last.routeId) ||
      selectRoute(task, routes)
    );
  return selectRoute(task, routes);
}

function taskContract(task, planPath) {
  return `Task ${task.id}: ${task.text}\nProfile: ${JSON.stringify({ type: task.type, complexity: task.complexity, risk: task.risk, scope: task.scope, uncertainty: task.uncertainty })}\nAcceptance criteria: ${task.acceptanceCriteria?.join(", ") || "read the plan mapping"}\nOwned files: ${task.files.join(", ") || "verification-only; do not expand ownership"}\nTest files: ${(task.testFiles || []).join(", ") || "none"}\nConsumes: ${JSON.stringify(task.consumes || [])}\nProduces: ${JSON.stringify(task.produces || [])}\nDefect class: ${task.defect || "read the plan"}\nReview boundary: ${task.reviewBoundary || "read the plan"}\nRED command: ${task.redVerify || "not applicable"}\nRED expected signal: ${task.redExpected || "not applicable"}\nGREEN verification: ${task.verify || "read the plan"}\nPlan: ${planPath}`;
}

function redWorkerPrompt(task, planPath, approvedTests, priorReview = null) {
  const hitlContext = approvedTests?.length
    ? `\nHITL-approved test set — write exactly these tests and no others:\n${approvedTests.map((test) => `- ${test.name} (${test.file}): ${test.purpose}`).join("\n")}`
    : "";
  const reviewContext = priorReview?.retry_context
    ? `\nA previous worker could not complete this slice. Re-read the repository evidence and resolve this bounded context without expanding the Review Slice:\n${priorReview.retry_context}`
    : priorReview?.findings?.length
    ? `\nA previous review rejected this slice. Correct these findings within the same Review boundary:\n${JSON.stringify(priorReview.findings, null, 2)}`
    : "";
  return `Execute only the RED phase of one behavior-sized pair Review Slice.\n\n${taskContract(task, planPath)}\n\nRead applicable AGENTS.md, the named repository contracts, existing callers, and existing tests before editing. Edit only the declared test files; do not edit production code, snapshots unrelated to the behavior, .pair files, or adjacent tasks. Write the smallest tests that expose the declared defect at the declared test boundary. Run the exact RED command. It must fail for the declared ${task.redMode} reason and contain the exact expected signal. If the command passes, fails in tooling, or requires an unavailable/later contract not produced by this same Review Slice, return blocked with a blocker beginning 'incorrect-plan:'.${reviewContext}${hitlContext}\nReturn only the requested structured result.`;
}

function workerPrompt(task, planPath, priorReview, approvedTests, singleSession = false) {
  const reviewContext = priorReview?.retry_context
    ? `\nA previous worker could not complete this slice. Re-read the repository evidence and resolve this bounded context without expanding the Review Slice:\n${priorReview.retry_context}`
    : priorReview?.findings?.length
    ? `\nThe previous review findings for this task are:\n${JSON.stringify(priorReview.findings, null, 2)}\nAddress them without expanding scope.`
    : "";
  const hitlContext = approvedTests?.length
    ? `\nThe RED phase used this HITL-approved test set. Do not add, remove, weaken, or rewrite those tests:\n${approvedTests.map((test) => `- ${test.name} (${test.file}): ${test.purpose}`).join("\n")}`
    : "";
  const phase = singleSession && task.type !== "docs" && (task.testFiles || []).length > 0
    ? `Complete this whole behavior-sized Review Slice in one session. Write the failing test first, run the exact RED command, and confirm the declared signal. Then implement only the minimum behavior needed to pass without weakening that test, and run the exact GREEN verification.`
    : task.tddMode === "cycle"
    ? "The coordinator has independently reproduced and preserved the RED phase. Implement only the minimum GREEN behavior. Do not modify any RED-verified test file."
    : "Work exactly one pair-plan Review Slice.";
  return `${phase}\n\n${taskContract(task, planPath)}\n\nRead the applicable AGENTS.md, the plan's Intent Contract, canonical specification, named Repository evidence, exact callers, and existing tests before editing. Legacy strict plans may also provide Capability Evidence, a Simplicity Contract, and explicit interface contracts; honor them when present. Do not invent APIs, wrappers, factories, registries, ports, or orchestration that the approved intent does not justify. If a load-bearing capability is absent, or this slice cannot be completed within its ownership, return blocked with a blocker beginning 'incorrect-plan:' and cite the observed evidence. Make the smallest complete implementation and run the exact verification. Do not edit any file under .pair/ or work on another task.${reviewContext}${hitlContext}\nReturn only the requested structured result.`;
}

// Inside a cmux pane the spawned worker/reviewer must reach the genuine Claude CLI,
// not cmux's shim, for two reasons the shim source (cmux-claude-wrapper) makes explicit:
//   1. It treats `-p` as a session entrypoint and injects `--session-id`, which
//      collides with our `--no-session-persistence` → the CLI exits in ~1s with empty
//      stdout, which pair-task can only read as an environment-failure.
//   2. Before launching the real CLI it clears the inherited session-identity env so
//      nested-session detection does not fire.
// The Codex CLI also receives the current session through CODEX_THREAD_ID. Pair workers
// and reviewers are deliberately separate, ephemeral runs, so neither runtime may inherit
// its coordinator's session identity. Strip the `cmux-cli-shims` dirs from PATH and clear
// the relevant runtime identity variables before spawning either CLI.
const NESTED_SESSION_ENV_KEYS = [
  "CODEX_THREAD_ID",
  "CLAUDECODE",
  "CLAUDE_CODE",
  "CLAUDE_CODE_CHILD_SESSION",
  "CLAUDE_CODE_BRIDGE_SESSION_ID",
  "CLAUDE_CODE_PARENT_SESSION_ID",
  "CLAUDE_CODE_SESSION_ID",
  "CLAUDE_CODE_ENTRYPOINT",
  "CLAUDE_CODE_EXECPATH",
  "CLAUDE_CODE_SSE_PORT",
];

function runtimeEnv() {
  const env = {
    ...process.env,
    PATH: (process.env.PATH || "")
      .split(path.delimiter)
      .filter((entry) => entry && !entry.includes("cmux-cli-shims"))
      .join(path.delimiter),
    PAIR_STOP_GATE: "off",
    CLAUDE_STOP_GATE: "off",
  };
  for (const key of NESTED_SESSION_ENV_KEYS) delete env[key];
  return env;
}

// A short, human-readable reason a spawn produced no usable result.
function runtimeDiagnostic(result) {
  if (result.error) return redactString(`spawn error: ${result.error.message}`);
  const stderr = redactString(result.stderr || "").trim();
  if (stderr) return stderr;
  if (!(result.stdout || "").trim())
    return `runtime exited ${result.status ?? "null"} with no output`;
  return "";
}

function assertPlainFreshRuntimeCommand(runtime, args) {
  if (!["codex", "claude"].includes(runtime)) throw new Error(`unsupported runtime ${runtime}`);
  if (!Array.isArray(args) || args.some(arg => /--(?:resume|continue|fork(?:-session)?)(?:=|\b)/iu.test(String(arg)))) {
    throw new Error("fresh Agent Conversation launch rejects resume and fork argv");
  }
}

function freshHandoverBootstrap(handoverId, runtime) {
  return [
    `Adopt Agent Conversation Handover ${handoverId} in this fresh ${runtime} agent conversation.`,
    `Run pair-loop --adopt-handover ${handoverId} --runtime ${runtime}.`,
  ].join(" ");
}

function launchFreshAgentConversation(root, input, dependencies = {}) {
  if (dependencies.nested ?? (isNestedCodexSandbox(process.env) || Boolean(process.env.CLAUDECODE))) {
    throw new Error("cannot launch a fresh Agent Conversation from a nested runtime");
  }
  const handover = readAgentConversationHandover(root, input.handoverId);
  const requestedRuntime = input.runtime || "auto";
  const runtime = requestedRuntime === "auto"
    ? handover.manifest.runtime
    : resolveRuntime(requestedRuntime, { available: input.available });
  const args = [freshHandoverBootstrap(input.handoverId, runtime)];
  assertPlainFreshRuntimeCommand(runtime, args);
  const spawn = dependencies.spawn || childProcess.spawn;
  const child = spawn(runtime, args, {
    cwd: root,
    detached: true,
    stdio: "ignore",
    env: runtimeEnv(),
  });
  if (child?.unref) child.unref();
  return { handoverId: input.handoverId, runtime, pid: child?.pid || null, bootstrap: args[0] };
}

function adoptFreshAgentConversation(root, input) {
  return adoptAgentConversationHandover(root, input);
}

function authorizeOneShotColdResume(root, input) {
  if (input.once !== true || input.confirmCostRisk !== true) {
    throw new Error("cold resume requires --once and --confirm-cost-risk");
  }
  return authorizeColdResume(root, input);
}

function runCommand(command, outputFile, timeoutMs, label = "model runtime", execution = {}) {
  return runObservableCommandSync({
    command,
    label,
    outputFile,
    hardTimeoutMs: timeoutMs,
    stallTimeoutMs: Number(
      process.env.PAIR_MODEL_STALL_TIMEOUT_MS || 5 * 60 * 1000,
    ),
    heartbeatMs: Number(process.env.PAIR_HEARTBEAT_MS || 15 * 1000),
    environmentMode: "pair-runtime",
    visible: execution.visible || null,
    stateContext: execution.stateContext || null,
  });
}

// parseError marks a result we synthesized because the runtime produced nothing we
// could parse into the worker schema — a toolchain failure, not a worker-authored
// blocker. classifyOutcome escalates it to a stronger route instead of retrying the
// same (often too-weak) model, and never trains routing on it.
function parseErrorWorkerResult(summary) {
  return {
    status: "blocked",
    summary:
      typeof summary === "string" && summary.trim()
        ? summary
        : "missing structured output",
    files_changed: [],
    tests: [],
    blocker: "unstructured result",
    parseError: true,
  };
}

// A syntactically valid result is still a parse failure if it is not shaped like the
// worker schema (no recognized status), so a weak model emitting `{}` escalates the
// same way non-JSON does — mirroring reviewIsWellFormed on the review side.
function asWorkerResult(candidate, summaryFallback) {
  if (
    candidate &&
    typeof candidate === "object" &&
    (candidate.status === "completed" || candidate.status === "blocked")
  ) {
    return candidate;
  }
  return parseErrorWorkerResult(summaryFallback);
}

function parseWorkerResult(runtime, raw, outputPath) {
  if (runtime === "codex")
    return asWorkerResult(readJson(outputPath), "missing structured output");
  const envelope = readJsonFromString(raw);
  const candidate = envelope?.structured_output || envelope?.result || envelope;
  if (typeof candidate === "string")
    return asWorkerResult(readJsonFromString(candidate), candidate);
  return asWorkerResult(candidate, "missing structured output");
}

function readJsonFromString(raw) {
  try {
    return JSON.parse(raw);
  } catch {
    return null;
  }
}

function isExpectedFailingTestTask(task) {
  return task.type === "test" && task.phase === "red" && task.tddMode === "red-contract";
}

function runVerificationCommand(root, command, label = "verification") {
  const scratchRoot = process.env.CLAUDE_SCRATCH_DIR
    || process.env.PAIR_SCRATCH_DIR
    || path.join(
      process.env.PAIR_DATA_DIR || path.join(os.homedir(), ".local", "share", "pair-v3"),
      "scratch",
    );
  const directory = path.join(scratchRoot, path.basename(root), "pair-v3", "verification");
  fs.mkdirSync(directory, { recursive: true, mode: 0o700 });
  const outputFile = path.join(
    directory,
    `${String(label).replace(/[^A-Za-z0-9._-]+/g, "-")}-${crypto.randomUUID().slice(0, 8)}.stdout`,
  );
  const run = runObservableCommandSync({
    command: { file: "bash", args: ["-lc", command], cwd: root },
    label: `verification ${label}`,
    outputFile,
    hardTimeoutMs: Number(
      process.env.PAIR_VERIFY_COMMAND_TIMEOUT_MS || 15 * 60 * 1000,
    ),
    stallTimeoutMs: Number(
      process.env.PAIR_VERIFY_STALL_TIMEOUT_MS || 5 * 60 * 1000,
    ),
    heartbeatMs: Number(process.env.PAIR_VERIFY_HEARTBEAT_MS || 15 * 1000),
  });
  return {
    command,
    status: run.status,
    signal: run.signal || null,
    output: `${run.stdout || ""}${run.stderr || ""}`.trim().slice(-4000),
    termination: run.termination || null,
    evidence: run.evidence,
  };
}

function verifyRed(root, task, snapshot = null) {
  if (!task.redVerify || !task.redExpected || !task.redMode) {
    return {
      status: "fail",
      command: task.redVerify || "missing RED command",
      output: "the task has no complete RED contract",
    };
  }
  const redOwnership = verifyOwnership(root, { ...task, files: task.testFiles || [] }, snapshot);
  if (redOwnership.status !== "pass") {
    return {
      status: "fail",
      command: "RED Review Slice ownership",
      output: redOwnership.output,
      ownership: redOwnership,
    };
  }
  const result = runVerificationCommand(root, task.redVerify, `${task.id || "task"} RED`);
  const matched = result.output.toLowerCase().includes(task.redExpected.toLowerCase());
  const hardInfrastructureFailure = /(?:command not found|no test files? found|no tests? (?:ran|were found|matched)|netsdk1064|nu1[0-9]{3}|timed? out)/i.test(result.output);
  const missingModule = /(?:err_module_not_found|cannot find module)/i.test(result.output);
  const declaredCompileModuleFailure = task.redMode === "compile"
    && matched
    && /(?:err_module_not_found|cannot find module)/i.test(task.redExpected);
  const infrastructureFailure = hardInfrastructureFailure
    || (missingModule && !declaredCompileModuleFailure);
  const reproduced = Number.isInteger(result.status)
    && result.status !== 0
    && matched
    && !infrastructureFailure;
  return {
    status: reproduced ? "pass" : "fail",
    command: task.redVerify,
    mode: task.redMode,
    expectedSignal: task.redExpected,
    exitCode: result.status,
    ownership: redOwnership,
    output: reproduced
      ? `RED ${task.redMode} failure reproduced with expected signal: ${task.redExpected}`
      : [
          `RED contract was not reproduced: expected non-zero ${task.redMode} failure containing "${task.redExpected}"`,
          infrastructureFailure ? "the command failed in the test/tooling infrastructure" : null,
          result.output,
        ].filter(Boolean).join("\n").slice(-4000),
  };
}

function untrackedHashes(root) {
  const paths = git(root, ["ls-files", "--others", "--exclude-standard"])
    .stdout.split("\n")
    .filter(Boolean);
  return Object.fromEntries(paths.map((file) => {
    const result = git(root, ["hash-object", "--", file]);
    return [file, result.status === 0 ? result.stdout.trim() : null];
  }));
}

function gitIndexFingerprint(root) {
  const resolved = git(root, ["rev-parse", "--git-path", "index"]);
  if (resolved.status !== 0 || !resolved.stdout.trim()) {
    throw new Error(
      `could not resolve the Git index: ${(resolved.stderr || resolved.stdout || `exit ${resolved.status}`).trim()}`,
    );
  }
  const indexPath = path.resolve(root, resolved.stdout.trim());
  if (!fs.existsSync(indexPath)) return { path: indexPath, digest: null };
  return { path: indexPath, digest: sha256(fs.readFileSync(indexPath)) };
}

function assertGitIndexUnchanged(root, snapshot) {
  if (!snapshot?.indexFingerprint) return;
  const current = gitIndexFingerprint(root);
  if (
    current.path !== snapshot.indexFingerprint.path ||
    current.digest !== snapshot.indexFingerprint.digest
  ) {
    throw new Error(
      "Git index changed after the metadata-free snapshot; refusing to compare or restore against an untrusted baseline",
    );
  }
}

function trackedWorktreeDirtyPaths(root) {
  const result = git(root, ["diff", "--name-only", "--"]);
  if (result.status !== 0) {
    throw new Error(
      `could not inspect tracked worktree changes: ${(result.stderr || result.stdout || `exit ${result.status}`).trim()}`,
    );
  }
  return result.stdout.split("\n").filter(Boolean);
}

function worktreePathExists(root, file) {
  try {
    fs.lstatSync(path.join(root, file));
    return true;
  } catch (error) {
    if (error.code === "ENOENT") return false;
    throw error;
  }
}

function worktreePathState(root, file) {
  const absolute = path.join(root, file);
  let stat;
  try {
    stat = fs.lstatSync(absolute);
  } catch (error) {
    if (error.code === "ENOENT") return { kind: "missing" };
    throw error;
  }
  const mode = stat.mode & 0o7777;
  if (stat.isSymbolicLink()) {
    return { kind: "symlink", target: fs.readlinkSync(absolute), mode };
  }
  if (stat.isFile()) {
    return { kind: "file", digest: sha256(fs.readFileSync(absolute)), mode };
  }
  throw new Error(`cannot snapshot non-file tracked path ${file}`);
}

function sameWorktreeState(left, right) {
  return JSON.stringify(left) === JSON.stringify(right);
}

function trackedChangesFromCopySnapshot(root, snapshot) {
  assertGitIndexUnchanged(root, snapshot);
  const current = trackedWorktreeDirtyPaths(root);
  const baseline = snapshot.trackedWorktreeStates || {};
  return [...new Set([...current, ...Object.keys(baseline)])]
    .filter((file) => {
      if (!(file in baseline)) return true;
      return !sameWorktreeState(baseline[file], worktreePathState(root, file));
    });
}

function restorePathsFromGitIndex(root, files, ignored = new Set()) {
  for (const file of files) {
    if (ignored.has(file)) continue;
    const staged = git(root, ["ls-files", "--stage", "--", file]);
    if (staged.status !== 0) {
      throw new Error(
        `could not read Git index entry for ${file}: ${(staged.stderr || staged.stdout || `exit ${staged.status}`).trim()}`,
      );
    }
    const target = path.join(root, file);
    const entries = staged.stdout.split("\n").filter(Boolean);
    if (entries.length === 0) {
      fs.rmSync(target, { recursive: true, force: true });
      continue;
    }
    const parsed = entries.length === 1
      ? entries[0].match(/^(\d{6}) [0-9a-f]+ 0\t/)
      : null;
    if (!parsed) {
      throw new Error(`cannot restore unmerged or malformed Git index entry for ${file}`);
    }
    const mode = parsed[1];
    if (mode === "160000") {
      throw new Error(`cannot restore changed submodule ${file} without Git metadata writes`);
    }
    const content = git(root, ["show", `:${file}`], {
      encoding: null,
      maxBuffer: 64 * 1024 * 1024,
    });
    if (content.status !== 0) {
      throw new Error(
        `could not read indexed bytes for ${file}: ${String(content.stderr || content.stdout || `exit ${content.status}`).trim()}`,
      );
    }
    fs.rmSync(target, { recursive: true, force: true });
    fs.mkdirSync(path.dirname(target), { recursive: true });
    if (mode === "120000") {
      fs.symlinkSync(content.stdout.toString(), target);
    } else {
      fs.writeFileSync(target, content.stdout, { mode: mode === "100755" ? 0o755 : 0o644 });
    }
  }
}

function changedPathsSinceSnapshot(root, snapshot) {
  if (!snapshot) return [];
  if (
    !snapshot.commit &&
    snapshot.dirty &&
    !Array.isArray(snapshot.trackedDirtyPaths)
  ) {
    throw new Error(
      "pre-attempt snapshot has no tracked baseline; refusing to compare against HEAD",
    );
  }
  let tracked;
  if (snapshot.strategy === "worktree-copy") {
    tracked = trackedChangesFromCopySnapshot(root, snapshot);
  } else {
    const source = snapshot.commit || "HEAD";
    const trackedDiff = git(root, ["diff", "--name-only", source, "--"]);
    if (trackedDiff.status !== 0) {
      throw new Error(
        `could not compare against the pre-attempt snapshot: ${(trackedDiff.stderr || trackedDiff.stdout || `exit ${trackedDiff.status}`).trim()}`,
      );
    }
    tracked = trackedDiff.stdout.split("\n").filter(Boolean);
  }
  const before = snapshot.untrackedHashes || {};
  const after = untrackedHashes(root);
  const untracked = Object.keys(after).filter((file) => before[file] !== after[file]);
  const removedUntracked = Object.keys(before).filter((file) => !(file in after));
  return [...new Set([...tracked, ...untracked, ...removedUntracked])].sort();
}

function verifyOwnership(root, task, snapshot) {
  const changed = changedPathsSinceSnapshot(root, snapshot)
    .filter((file) => !isPairRuntimeArtifact(file));
  const owned = new Set(task.files || []);
  const additional = changed.filter((file) => !owned.has(file));
  const hardBoundaries = additional.filter((file) => {
    const normalized = file.split(path.sep).join("/");
    const base = path.posix.basename(normalized).toLowerCase();
    return normalized === ".pair/plan.md" ||
      normalized === ".pair/spec.md" ||
      (normalized.startsWith("docs/work/") && normalized.endsWith("/spec.md")) ||
      normalized.startsWith("../") ||
      normalized.startsWith("/") ||
      base === ".env" ||
      base.startsWith(".env.") ||
      /(?:credential|credentials|secrets?)\.(?:json|ya?ml|toml)$/iu.test(base) ||
      /\.(?:pem|key|p12|pfx)$/iu.test(base);
  });
  const advisory = additional.filter((file) => !hardBoundaries.includes(file));
  const status = hardBoundaries.length > 0
    ? "fail"
    : advisory.length > 0
      ? "warn"
      : "pass";
  return {
    status,
    changed,
    expected: changed.filter((file) => owned.has(file)),
    additional: advisory,
    hardBoundaries,
    outside: hardBoundaries.length > 0 ? hardBoundaries : advisory,
    output: hardBoundaries.length > 0
      ? `hard Pair boundary crossed: ${hardBoundaries.join(", ")}`
      : advisory.length > 0
        ? `attribution warning: additional repository files will remain in the complete review patch: ${advisory.join(", ")}`
        : "attempt changes match expected Review Slice files",
  };
}

function verify(root, task, workerResult, snapshot = null, greenSnapshot = null) {
  const diffCheck = git(root, ["diff", "--check"]);
  if (diffCheck.status !== 0)
    return {
      status: "fail",
      command: "git diff --check",
      output: `${diffCheck.stdout}${diffCheck.stderr}`.trim(),
    };
  const ownership = verifyOwnership(root, task, snapshot);
  if (ownership.status !== "pass") {
    if (ownership.status === "warn") {
      console.warn(`pair-loop: ${ownership.output}`);
    } else {
      return {
        status: "fail",
        command: "Review Slice ownership",
        output: ownership.output,
        ownership,
      };
    }
  }

  if (greenSnapshot && task.testFiles?.length) {
    const changedDuringGreen = changedPathsSinceSnapshot(root, greenSnapshot);
    const mutatedTests = changedDuringGreen.filter((file) => task.testFiles.includes(file));
    if (mutatedTests.length > 0) {
      return {
        status: "fail",
        command: "TDD phase separation",
        output: `GREEN phase modified RED-verified tests: ${mutatedTests.join(", ")}`,
        ownership,
      };
    }
  }

  if (isExpectedFailingTestTask(task)) return verifyRed(root, task, snapshot);

  if (task.verify?.trim()) {
    const result = runVerificationCommand(root, task.verify, `${task.id || "task"} GREEN`);
    return {
      status: result.status === 0 ? "pass" : "fail",
      command: task.verify,
      output: result.output,
      ownership,
      termination: result.termination,
      signal: result.signal,
      evidence: result.evidence,
      exit_status: result.status,
    };
  }

  const verifyScript = path.join(root, ".pair", "verify.sh");
  if (
    fs.existsSync(verifyScript) &&
    fs.statSync(verifyScript).mode & 0o111
  ) {
    const result = runVerificationCommand(
      root,
      "./.pair/verify.sh",
      `${task.id || "task"} verify.sh`,
    );
    return {
      status: result.status === 0 ? "pass" : "fail",
      command: ".pair/verify.sh",
      output: result.output,
      termination: result.termination,
      signal: result.signal,
      evidence: result.evidence,
      exit_status: result.status,
    };
  }

  const reported = (workerResult.tests || []).filter(
    (test) => test.status !== "not-run" && test.command?.trim(),
  );
  if (reported.length === 0) {
    return {
      status: "fail",
      command: "git diff --check + replayed worker verification",
      output:
        "no replayable verification command was reported; add .pair/verify.sh or run a focused check",
    };
  }

  const results = reported.map((test) => {
    return runVerificationCommand(root, test.command, `${task.id || "task"} worker replay`);
  });
  const passed = results.every((result) => result.status === 0);
  return {
    status: passed ? "pass" : "fail",
    command: "git diff --check + replayed worker verification",
    output: results
      .map(
        (result) =>
          `${result.status === 0 ? "PASS" : "FAIL"}: ${result.command}${result.output ? `\n${result.output}` : ""}`,
      )
      .join("\n")
      .slice(-2000),
    ownership,
    termination: results.find((result) => result.termination)?.termination || null,
    signal: results.find((result) => result.signal)?.signal || null,
    evidence: results.map((result) => result.evidence).filter(Boolean),
    exit_statuses: results.map((result) => result.status),
  };
}

// The loop does not commit between tasks, so HEAD's tree accumulates earlier accepted
// uncommitted work. Prefer a synthetic stash commit when Git metadata is writable. In a
// hosted sandbox where `.git` is read-only, preserve the same worktree invariant with
// scratch copies and an immutable index fingerprint instead of weakening ownership.
function createSnapshotDirectory(scratchRoot) {
  if (!scratchRoot) return null;
  fs.mkdirSync(scratchRoot, { recursive: true, mode: 0o700 });
  return fs.mkdtempSync(path.join(scratchRoot, "worktree-snapshot-"));
}

function copyWorktreePaths(root, files, snapshotDirectory, bucket) {
  if (!snapshotDirectory || files.length === 0) return {};
  const copies = {};
  for (const file of files) {
    const source = path.join(root, file);
    let stat;
    try {
      stat = fs.lstatSync(source);
    } catch (error) {
      if (error.code === "ENOENT") {
        copies[file] = { kind: "missing" };
        continue;
      }
      throw error;
    }
    if (stat.isSymbolicLink()) {
      const copy = path.join(snapshotDirectory, bucket, file);
      fs.mkdirSync(path.dirname(copy), { recursive: true });
      fs.symlinkSync(fs.readlinkSync(source), copy);
      copies[file] = {
        kind: "symlink",
        target: fs.readlinkSync(source),
        path: copy,
        mode: stat.mode & 0o7777,
      };
      continue;
    }
    if (!stat.isFile()) {
      throw new Error(`cannot snapshot non-file path ${file}`);
    }
    const copy = path.join(snapshotDirectory, bucket, file);
    fs.mkdirSync(path.dirname(copy), { recursive: true });
    fs.copyFileSync(source, copy);
    fs.chmodSync(copy, stat.mode);
    copies[file] = {
      kind: "file",
      path: copy,
      mode: stat.mode & 0o7777,
    };
  }
  return copies;
}

function restoreWorktreeCopies(root, copies, ignored = new Set()) {
  for (const [file, copy] of Object.entries(copies || {})) {
    if (ignored.has(file)) continue;
    const target = path.join(root, file);
    fs.rmSync(target, { recursive: true, force: true });
    if (copy.kind === "missing") continue;
    fs.mkdirSync(path.dirname(target), { recursive: true });
    if (copy.kind === "symlink") fs.symlinkSync(copy.target, target);
    else if (copy.kind === "file") {
      fs.copyFileSync(copy.path, target);
      fs.chmodSync(target, copy.mode);
    }
  }
}

function snapshotWorktree(root, scratchRoot = null) {
  const head = git(root, ["rev-parse", "--verify", "--quiet", "HEAD"]);
  if (head.status !== 0 && head.status !== 1) {
    throw new Error(
      `could not inspect the Git baseline: ${(head.stderr || head.stdout || `exit ${head.status}`).trim()}`,
    );
  }
  const hasHead = head.status === 0;
  const trackedDirty = git(
    root,
    hasHead
      ? ["diff", "--name-only", "HEAD", "--"]
      : ["diff", "--name-only", "--"],
  );
  if (trackedDirty.status !== 0) {
    throw new Error(
      `could not inspect pre-attempt tracked changes: ${(trackedDirty.stderr || trackedDirty.stdout || `exit ${trackedDirty.status}`).trim()}`,
    );
  }
  const trackedDirtyPaths = trackedDirty.stdout.split("\n").filter(Boolean);
  const stash = hasHead && trackedDirtyPaths.length > 0
    ? git(root, ["stash", "create", "pair-v3 pre-attempt snapshot"])
    : { status: 0, stdout: "", stderr: "" };
  const untracked = git(root, ["ls-files", "--others", "--exclude-standard"])
    .stdout.split("\n")
    .filter(Boolean);
  const dirty = Boolean(git(root, ["status", "--porcelain"]).stdout.trim());
  const commit = stash.status === 0 ? stash.stdout.trim() || null : null;
  let strategy = commit ? "git-commit" : hasHead ? "head" : "worktree-copy";
  let indexFingerprint = null;
  let trackedWorktreeStates = {};
  let trackedCopies = {};
  let snapshotDirectory = null;
  if (!hasHead || (trackedDirtyPaths.length > 0 && !commit)) {
    const diagnostic = `${stash.stderr || ""}\n${stash.stdout || ""}`.trim();
    const metadataDenied = /index\.lock|operation not permitted|permission denied|unable to write|could not write|insufficient permission/i
      .test(diagnostic);
    if (hasHead && (!metadataDenied || !scratchRoot)) {
      throw new Error(
        `could not snapshot pre-attempt tracked changes: ${trackedDirtyPaths.join(", ")}${diagnostic ? ` (${diagnostic.split("\n")[0]})` : ""}`,
      );
    }
    strategy = "worktree-copy";
    indexFingerprint = gitIndexFingerprint(root);
    const worktreePaths = trackedWorktreeDirtyPaths(root);
    trackedWorktreeStates = Object.fromEntries(
      worktreePaths.map((file) => [file, worktreePathState(root, file)]),
    );
    snapshotDirectory = createSnapshotDirectory(scratchRoot);
    trackedCopies = copyWorktreePaths(
      root,
      worktreePaths,
      snapshotDirectory,
      "tracked",
    );
  }
  if (untracked.length > 0 && !snapshotDirectory) {
    snapshotDirectory = createSnapshotDirectory(scratchRoot);
  }
  const untrackedCopies = copyWorktreePaths(
    root,
    untracked,
    snapshotDirectory,
    "untracked",
  );
  return {
    commit,
    strategy,
    indexFingerprint,
    trackedDirtyPaths,
    trackedWorktreeStates,
    trackedCopies,
    untracked,
    untrackedHashes: untrackedHashes(root),
    snapshotDirectory,
    untrackedCopies,
    dirty,
  };
}

function writeReviewSlicePatch(root, task, snapshot, outputFile) {
  const source = snapshot?.commit || "HEAD";
  const changed = changedPathsSinceSnapshot(root, snapshot)
    .filter((file) => !isPairRuntimeArtifact(file));
  const expected = new Set(task.files || []);
  const expectedChanged = changed.filter((file) => expected.has(file));
  const additionalChanged = changed.filter((file) => !expected.has(file));
  const handledTracked = new Set();
  const chunks = [
    `Review Slice task: ${task.id}`,
    `Acceptance Criteria: ${(task.acceptanceCriteria || []).join(", ")}`,
    `Expected files: ${(task.files || []).join(", ")}`,
    `Expected changed files: ${expectedChanged.join(", ") || "none"}`,
    `Additional changed files (advisory attribution): ${additionalChanged.join(", ") || "none"}`,
    `Complete changed files: ${changed.join(", ") || "none"}`,
    "",
  ];
  if (snapshot?.strategy === "worktree-copy") {
    for (const file of changed) {
      const baseline = snapshot.trackedCopies?.[file];
      if (baseline) {
        const before = baseline.kind === "missing" ? "/dev/null" : baseline.path;
        const absolute = path.join(root, file);
        const after = worktreePathExists(root, file)
          ? absolute
          : "/dev/null";
        const delta = git(root, ["diff", "--no-index", "--binary", "--", before, after]);
        if (delta.status > 1) {
          throw new Error(
            `could not build Review Slice delta for ${file}: ${(delta.stderr || delta.stdout).trim()}`,
          );
        }
        if (delta.stdout) chunks.push(delta.stdout);
        handledTracked.add(file);
        continue;
      }
      if (git(root, ["ls-files", "--error-unmatch", "--", file]).status === 0) {
        const delta = git(root, ["diff", "--binary", "--", file]);
        if (delta.status !== 0) {
          throw new Error(
            `could not build Review Slice delta for ${file}: ${(delta.stderr || delta.stdout).trim()}`,
          );
        }
        if (delta.stdout) chunks.push(delta.stdout);
        handledTracked.add(file);
      }
    }
  } else if (changed.length > 0) {
    const tracked = git(root, ["diff", "--binary", source, "--", ...changed]);
    if (tracked.stdout) chunks.push(tracked.stdout);
  }
  const before = snapshot?.untrackedHashes || {};
  for (const file of changed) {
    if (handledTracked.has(file)) continue;
    if (git(root, ["ls-files", "--error-unmatch", "--", file]).status === 0) continue;
    if (file in before) {
      const copy = snapshot?.untrackedCopies?.[file];
      if (copy?.kind === "file") {
        const target = fs.existsSync(path.join(root, file))
          ? file
          : "/dev/null";
        const changed = git(root, [
          "diff",
          "--no-index",
          "--binary",
          "--",
          copy.path,
          target,
        ]);
        if (changed.stdout) chunks.push(changed.stdout);
      } else {
        chunks.push(`Pre-existing untracked ${file} changed; binary/symlink delta unavailable.`);
      }
      continue;
    }
    const created = git(root, ["diff", "--no-index", "--binary", "--", "/dev/null", file]);
    if (created.stdout) chunks.push(created.stdout);
  }
  fs.writeFileSync(outputFile, redactString(chunks.join("\n")), { mode: 0o600 });
  return {
    path: outputFile,
    changed,
    expected: expectedChanged,
    additional: additionalChanged,
  };
}

// Restore the worktree to the pre-attempt snapshot after a rejected attempt so the next
// (usually stronger) route starts from a clean canvas instead of paying to comprehend and
// undo the failed attempt's code. The rejected work is saved as a scratch patch first.
// Pair-owned active markers and review evidence survive the revert so the coordinator and
// next attempt retain their state. Other `.pair/` changes are worker changes and restore too.
function revertToSnapshot(root, snapshot, rejectedPatchFile) {
  if (
    !snapshot?.commit &&
    snapshot?.dirty &&
    !Array.isArray(snapshot?.trackedDirtyPaths)
  ) {
    throw new Error(
      "pre-attempt snapshot has no tracked baseline; refusing to restore from HEAD",
    );
  }
  if (snapshot?.strategy === "worktree-copy") {
    assertGitIndexUnchanged(root, snapshot);
  }
  const trackedToRestore = snapshot?.strategy === "worktree-copy"
    ? trackedChangesFromCopySnapshot(root, snapshot)
    : [];
  // Capture the untracked list BEFORE writing the patch so the patch itself can never
  // be swept up as an attempt-introduced file when it lands inside the repository.
  const preexisting = new Set(snapshot?.untracked || []);
  const nowUntracked = git(root, ["ls-files", "--others", "--exclude-standard"])
    .stdout.split("\n")
    .filter(Boolean);
  const diff = git(root, ["diff", "HEAD"]).stdout || "";
  if (diff.trim()) fs.writeFileSync(rejectedPatchFile, redactString(diff), { mode: 0o600 });
  for (const file of nowUntracked) {
    if (!preexisting.has(file) && !PAIR_POST_ATTEMPT_EVIDENCE.has(file)) {
      fs.rmSync(path.join(root, file), { recursive: true, force: true });
    }
  }
  restoreWorktreeCopies(
    root,
    snapshot?.untrackedCopies,
    PAIR_POST_ATTEMPT_EVIDENCE,
  );
  if (snapshot?.strategy === "worktree-copy") {
    restorePathsFromGitIndex(root, trackedToRestore, PAIR_POST_ATTEMPT_EVIDENCE);
    restoreWorktreeCopies(root, snapshot.trackedCopies, PAIR_POST_ATTEMPT_EVIDENCE);
    assertGitIndexUnchanged(root, snapshot);
  } else {
    const restore = git(root, [
      "restore",
      "--source",
      snapshot?.commit || "HEAD",
      "--worktree",
      "--staged",
      "--",
      ".",
      ":(exclude).pair/active-attempt.json",
      ":(exclude).pair/active-loop.json",
      ":(exclude).pair/review.json",
      ":(exclude).pair/review.md",
    ]);
    if (restore.status !== 0) {
      throw new Error(
        `could not restore the pre-attempt snapshot: ${(restore.stderr || restore.stdout || `exit ${restore.status}`).trim()}`,
      );
    }
  }
  const rejectedPatchRelative = path.relative(root, rejectedPatchFile)
    .split(path.sep)
    .join("/");
  const remaining = changedPathsSinceSnapshot(root, snapshot)
    .filter((file) =>
      !PAIR_POST_ATTEMPT_EVIDENCE.has(file) &&
      (rejectedPatchRelative.startsWith("../") || file !== rejectedPatchRelative)
    );
  if (remaining.length > 0) {
    const error = new Error(
      `pre-attempt snapshot did not restore exactly: ${remaining.join(", ")}`,
    );
    error.remainingPaths = remaining;
    throw error;
  }
}

function restorationFailurePath(root) {
  return path.join(root, ".pair", "restoration-failure.json");
}

function recordRestorationFailure(root, task, attempt, error) {
  const marker = {
    schema: 1,
    task_id: task.id,
    attempt_id: attempt.attemptId,
    recorded_at: new Date().toISOString(),
    reason: error.message,
    remaining_paths: error.remainingPaths || [],
  };
  fs.writeFileSync(
    restorationFailurePath(root),
    `${JSON.stringify(marker, null, 2)}\n`,
    { mode: 0o600 },
  );
  return marker;
}

function cleanupWorktreeSnapshots(...snapshots) {
  for (const directory of new Set(
    snapshots.map(snapshot => snapshot?.snapshotDirectory).filter(Boolean),
  )) {
    fs.rmSync(directory, { recursive: true, force: true });
  }
}

function resolveBase(root) {
  const remote = git(root, ["rev-parse", "--abbrev-ref", "origin/HEAD"]);
  if (
    remote.status === 0 &&
    remote.stdout.trim() &&
    remote.stdout.trim() !== "origin/HEAD"
  )
    return remote.stdout.trim();
  for (const ref of ["origin/main", "origin/master", "main", "master"]) {
    if (git(root, ["rev-parse", "--verify", "--quiet", ref]).status === 0)
      return ref;
  }
  return "HEAD";
}

// The reviewer reports ONLY material findings. Every finding must carry a concrete
// failure_scenario this repository can actually reach — sensible-sounding but
// unreachable-in-production observations are noise that burns fix cycles and tokens.
function reviewPrompt(
  task,
  base,
  planPath,
  reviewSlicePath,
  redVerification,
  priorReview = null,
  cumulative = false,
) {
  const priorFindings = Array.isArray(priorReview?.findings)
    ? priorReview.findings.filter((finding) => finding?.origin !== "environment")
    : [];
  const reviewMode = priorFindings.length > 0
    ? `This is a closure review after one rejected implementation. Verify these prior findings first:\n${JSON.stringify(priorFindings, null, 2)}\nInspect only their fixes and contracts directly affected by the new patch. Do not restart a broad repository audit or reopen unchanged aspects without concrete regression evidence.`
    : "This is the first review of this Review Slice. Perform one complete bounded sweep and report every material finding together.";
  if (cumulative) {
    return `Independently review the complete cumulative implementation for this Pair Work. This is the single terminal quality verdict, not another task-planning pass.\nBase: ${base}\nPlan: ${planPath}\nCumulative patch: ${reviewSlicePath}\nAcceptance Criteria: ${(task.acceptanceCriteria || []).join(", ")}\nFinal verification evidence: ${redVerification ? JSON.stringify(redVerification) : "not available"}\n\n${reviewMode}\n\nRead the cumulative patch and plan first. Trace only the exact callers, dependencies, contracts, and tests needed to decide every mapped Acceptance Criterion. Perform one bounded sweep (at most 12 batched shell commands) and report every material finding together. Do not reopen plan design choices that the implementation satisfies, and do not report style, optional hardening, speculative edge cases, or improvements without a concrete reachable failure.\n\nReport only BLOCKER or MAJOR findings. BLOCKER means a mapped Acceptance Criterion, declared contract, security/data-integrity invariant, or final verification is not actually satisfied. MAJOR means the cumulative implementation produces wrong behavior in a concrete reachable scenario. Set origin to implementation when the Work can be corrected locally, plan when the approved contract itself must change, or environment when evidence cannot be obtained. Approve with an empty findings array when the Work is acceptable. Do not edit files. Return only the requested structured result.`;
  }
  return `Independently review the immutable complete changed-file patch for task ${task.id}: ${task.text}.\nBase: ${base}\nPlan: ${planPath}\nReview Slice patch: ${reviewSlicePath}\nAcceptance Criteria: ${(task.acceptanceCriteria || []).join(", ")}\nConsumes: ${JSON.stringify(task.consumes || [])}\nProduces: ${JSON.stringify(task.produces || [])}\nDefect class: ${task.defect || "read the task contract"}\nReview boundary: ${task.reviewBoundary || "read the task contract"}\nRED evidence: ${redVerification ? JSON.stringify(redVerification) : "not applicable"}\n\n${reviewMode}\n\nRead the complete changed-file patch first. It includes expected files and any additional files with advisory attribution; review all of them on their substance. Inspect only those changed files plus the exact callers, dependencies, and contracts needed to verify this slice. Read the Intent Contract, canonical specification, named Repository evidence, mapped Acceptance Criteria, and any legacy strict interface/Simplicity contracts that are actually present. Budget at most 8 shell commands, batching related reads where useful, and report all material findings together.\n\nReport ONLY material findings:\n- BLOCKER: the slice violates a mapped Acceptance Criterion, declared interface, tests-first evidence, security/data integrity, or an approved constraint.\n- MAJOR: the slice produces wrong behavior in a concrete reachable scenario.\n\nA file being additional to the expected-file forecast is not itself a finding. Set origin to implementation for a local correction, plan when ownership/interfaces/acceptance mapping must change, or environment when trustworthy evidence is unavailable. Do not report style, naming, hypothetical edges, optional hardening, performance speculation, or improvement ideas. If no concrete reachable failure exists, approve with an empty findings array. Do not edit files. Return only the requested structured result.`;
}

function runReview({
  runtime,
  route,
  root,
  task,
  planPath,
  scratchDir,
  attemptId,
  timeoutMs,
  dryRun,
  anchor = false,
  reviewSlicePath = "(review slice not provided)",
  redVerification = null,
  externalSandbox = runtime === "codex" && isNestedCodexSandbox(process.env),
  priorReview = null,
  cumulative = false,
}) {
  const schema = readJson(REVIEW_SCHEMA_PATH);
  const outputPath = path.join(scratchDir, `${attemptId}.review-result.json`);
  const rawPath = path.join(scratchDir, `${attemptId}.review-events.jsonl`);
  const base = resolveBase(root);
  const reviewEffort = anchor
    ? "high"
    : task.risk === "low"
      ? "low"
      : task.risk === "critical"
        ? "high"
        : "medium";
  const resolvedReviewSlicePath = path.resolve(root, reviewSlicePath);
  const reviewArtifacts = fs.existsSync(resolvedReviewSlicePath)
    ? [resolvedReviewSlicePath]
    : [];
  const snapshot = externalSandbox && !dryRun
    ? createReviewSnapshot(root, scratchDir, reviewArtifacts)
    : null;
  const reviewRoot = snapshot?.directory || root;
  const resolvedPlanPath = path.resolve(root, planPath);
  const reviewPlanPath = snapshot && resolvedPlanPath.startsWith(`${path.resolve(root)}${path.sep}`)
    ? path.join(reviewRoot, path.relative(root, resolvedPlanPath))
    : planPath;
  const reviewArtifact = snapshot?.artifacts.find(
    artifact => artifact.sourcePath === resolvedReviewSlicePath,
  );
  const reviewPatchPath = reviewArtifact
    ? path.join(reviewRoot, reviewArtifact.relativePath)
    : reviewSlicePath;
  const reviewModel = runtime === "codex"
    ? anchor
      ? process.env.PAIR_CODEX_ANCHOR_MODEL || "default"
      : process.env.PAIR_CODEX_REVIEW_MODEL || "default"
    : anchor
      ? process.env.PAIR_CLAUDE_ANCHOR_MODEL || "opus"
      : process.env.PAIR_CLAUDE_REVIEW_MODEL ||
        (task.risk === "low" ? "sonnet" : "opus");
  const reviewSession = readReviewSession(root, runtime, snapshot?.digest || null);
  const fullReviewPrompt = reviewPrompt(
    task,
    base,
    reviewPlanPath,
    reviewPatchPath,
    redVerification,
    priorReview,
    cumulative,
  );
  let resumeCheckpoint = null;
  let effectivePrompt = fullReviewPrompt;
  if (reviewSession?.session_id) {
    const state = loadPairState(root);
    const planFile = path.resolve(root, planPath);
    const patchFile = path.resolve(reviewSlicePath);
    const relativePatch = patchFile.startsWith(`${path.resolve(root)}${path.sep}`)
      ? path.relative(root, patchFile).split(path.sep).join("/")
      : null;
    if (state.work_id && fs.existsSync(planFile) && relativePatch && fs.existsSync(patchFile)) {
      resumeCheckpoint = createResumeCheckpoint({
        workId: state.work_id,
        runtime,
        role: "reviewer",
        phase: cumulative ? "cumulative-review" : "reviewing",
        sessionId: reviewSession.session_id,
        attemptId,
        taskId: task.id,
        plan: {
          path: path.relative(root, planFile).split(path.sep).join("/"),
          sha256: planContractDigest(fs.readFileSync(planFile, "utf8")),
        },
        patch: { path: relativePatch, sha256: sha256(fs.readFileSync(patchFile)) },
        resumeTarget: cumulative ? "cumulative-review" : "reviewing",
        nextAction: cumulative
          ? `Read the complete Work patch at ${relativePatch}, verify every mapped Acceptance Criterion, and return one final structured verdict.`
          : `Read the complete changed-file patch at ${relativePatch}, including advisory additional files, and return one structured verdict for task ${task.id}.`,
        acceptanceCriteria: task.acceptanceCriteria || [],
        findingIds: (priorReview?.findings || []).map((finding, index) =>
          finding.id || `${finding.severity || "finding"}-${index + 1}`),
      });
      effectivePrompt = `Pair v4 Resume Checkpoint (Pair-authored context is bounded; do not request a cache-warming turn):\n${serializeResumeCheckpoint(resumeCheckpoint)}\nExecute next_action now. Read referenced artifacts from the repository and return only the requested structured result.`;
    }
  }
  const command = buildReviewRuntimeCommand({
    runtime,
    root: reviewRoot,
    prompt: effectivePrompt,
    schemaPath: REVIEW_SCHEMA_PATH,
    schema,
    outputPath,
    model: reviewModel,
    effort: runtime === "claude" && anchor ? "max" : reviewEffort,
    externalSandbox,
    reviewerSessionId: reviewSession?.session_id || null,
  });
  if (dryRun)
    return {
      status: 0,
      command,
      review: {
        verdict: "approve",
        recommended_action: "approve",
        summary: "dry run",
        findings: [],
      },
      usage: null,
      elapsedMs: 0,
    };
  const result = runCommand(
    command,
    rawPath,
    timeoutMs,
    `${anchor ? "anchor review" : "task review"} ${task.id}`,
    {
      visible: process.env.PAIR_REVIEW_TRANSPORT === "direct"
        ? null
        : { root, role: "reviewer" },
      stateContext: {
        root,
        workId: loadPairState(root).work_id || null,
        attemptId: cumulative ? null : attemptId.replace(/\.anchor$/u, ""),
        phase: cumulative ? "cumulative-review" : "reviewing",
        requestKind: cumulative ? "cumulative-review" : anchor ? "anchor-review" : "slice-review",
      },
    },
  );
  const savedReviewSession = saveReviewSession(root, {
    runtime,
    stdout: result.stdout || "",
    plannedSessionId: command.reviewerSessionId || null,
    // A reviewer that never completed did not establish a resumable session; persisting
    // its planned id would poison the reusable Review Session (see review-session.js).
    runSucceeded: !result.error && (result.status ?? 1) === 0,
    model: reviewModel,
    effort: runtime === "claude" && anchor ? "max" : reviewEffort,
    phase: cumulative ? "cumulative-review" : anchor ? "anchor-review" : "slice-review",
    snapshotDigest: snapshot?.digest || null,
  });
  const snapshotMutated = snapshot && treeDigest(snapshot.directory) !== snapshot.digest;
  const sourceMutated = snapshot
    && (
      repositoryDigest(root, scratchDir) !== snapshot.sourceDigest
      || reviewArtifactDigest(snapshot.artifacts) !== snapshot.artifactDigest
    );
  const parsed =
    runtime === "codex"
      ? readJson(outputPath)
      : parseWorkerResult("claude", result.stdout || "", outputPath);
  if (fs.existsSync(outputPath)) {
    const safeOutput = parsed && typeof parsed === "object"
      ? `${JSON.stringify(sanitizeValue(parsed), null, 2)}\n`
      : redactString(fs.readFileSync(outputPath, "utf8"));
    fs.writeFileSync(outputPath, safeOutput, { mode: 0o600 });
  }
  // A truncated or unparseable reviewer result must not pass as a real verdict. Force a
  // failed review status so classifyOutcome treats it as reviewer-error and retries,
  // and always hand back a schema-shaped review so file writing cannot crash.
  const wellFormed = reviewIsWellFormed(parsed);
  const usage = parseRuntimeUsage(runtime, result.stdout || "");
  if (resumeCheckpoint) {
    recordResumedTurn(root, {
      checkpoint: resumeCheckpoint,
      usage,
      runtime,
      role: "reviewer",
      phase: cumulative ? "cumulative-review" : "reviewing",
    });
  }
  if (snapshot) fs.rmSync(snapshot.directory, { recursive: true, force: true });
  if (snapshotMutated || sourceMutated) {
    console.error(
      `pair-loop: task ${task.id} ${sourceMutated ? "source repository" : "review snapshot"} mutated; refusing to use the reviewer verdict`,
    );
  }
  if (!wellFormed) {
    console.error(
      `pair-loop: task ${task.id} review result was not schema-shaped; treating as reviewer-error (see ${rawPath})`,
    );
  }
  return {
    status: wellFormed && !snapshotMutated && !sourceMutated ? (result.status ?? 1) : 1,
    command,
    review: normalizeReview(parsed),
    usage,
    elapsedMs: result.elapsedMs ?? null,
    reviewerSessionId: savedReviewSession?.session_id || command.reviewerSessionId || null,
  };
}

function shouldRunAnchorReview(attemptId, task, review, env = process.env) {
  if (review.verdict !== "approve" || task.risk === "critical") return false;
  const rate = Number(env.PAIR_ANCHOR_REVIEW_RATE || 0);
  if (!(rate > 0)) return false;
  const bucket = Number.parseInt(attemptId.slice(-2), 16) / 255;
  return bucket < Math.min(rate, 1);
}

function shouldRunTaskReview(task, options = {}, env = process.env) {
  if (options.independentReview === false) return false;
  if (options.legacyV3) return true;
  const policy = String(env.PAIR_TASK_REVIEW || "critical").toLowerCase();
  if (policy === "all") return true;
  if (["off", "none", "final-only"].includes(policy)) return false;
  if (policy === "high-risk") {
    return task.risk === "high" || task.risk === "critical";
  }
  return task.risk === "critical";
}

function writeReviewFiles(root, review) {
  const safeReview = sanitizeValue(review) || {};
  const dir = path.join(root, ".pair");
  fs.mkdirSync(dir, { recursive: true, mode: 0o700 });
  fs.writeFileSync(
    path.join(dir, "review.json"),
    `${JSON.stringify(safeReview, null, 2)}\n`,
    { mode: 0o600 },
  );
  const findingsList = Array.isArray(safeReview.findings) ? safeReview.findings : [];
  const findings =
    findingsList.length === 0
      ? "No findings."
      : findingsList
          .map(
            (finding) =>
              `### ${finding.severity}: ${finding.title}\n- **Origin:** ${finding.origin || "implementation"}\n- **File:** \`${finding.file}:${finding.line}\`\n- **Issue:** ${finding.detail}\n- **Failure scenario:** ${finding.failure_scenario || "not stated"}\n- **Suggested fix:** ${finding.suggestion}`,
          )
          .join("\n\n");
  fs.writeFileSync(
    path.join(dir, "review.md"),
    redactString(`## Summary\n${safeReview.summary || ""}\n\n## Findings\n${findings}\n\n## Verdict\n${safeReview.verdict || "fix-needed"}\n`),
    { mode: 0o600 },
  );
}

function cumulativeBase(ledger, repositoryIdValue, workId, planDigest) {
  const started = ledger.find((record) =>
    ["attempt.started", "attempt.completed"].includes(record.event) &&
    record.repositoryId === repositoryIdValue &&
    (workId ? record.workId === workId : record.planDigest === planDigest) &&
    (record.snapshotCommit || record.snapshot?.commit || record.baselineCommit),
  );
  return started?.snapshotCommit || started?.snapshot?.commit || started?.baselineCommit || "HEAD";
}

function writeCumulativeReviewPatch(
  root,
  plan,
  ledger,
  linkage,
  repositoryIdValue,
  outputFile,
) {
  const parsed = parsePlan(plan);
  const forecast = new Set(parsed.tasks.flatMap((task) => task.files || []));
  const base = cumulativeBase(
    ledger,
    repositoryIdValue,
    linkage.workId,
    linkage.planDigest,
  );
  const trackedChanged = git(root, ["diff", "--name-only", base, "--"]);
  if (trackedChanged.status !== 0) {
    throw new Error(
      `cannot identify cumulative changes from ${base}: ${(trackedChanged.stderr || trackedChanged.stdout).trim()}`,
    );
  }
  const observed = [
    ...trackedChanged.stdout.split("\n").filter(Boolean),
    ...git(root, ["ls-files", "--others", "--exclude-standard"]).stdout
      .split("\n")
      .filter(Boolean),
  ].filter((file) => !file.startsWith(".pair/") && !isPairRuntimeArtifact(file));
  const accepted = ledger
    .filter((record) =>
      ["attempt.completed", "attempt.outcome"].includes(record.event) &&
      record.disposition === "accepted" &&
      record.repositoryId === repositoryIdValue &&
      (linkage.workId ? record.workId === linkage.workId : record.planDigest === linkage.planDigest),
    )
    .flatMap((record) => record.verification?.ownership?.changed || record.reviewSlice?.changed || [])
    .filter((file) => !file.startsWith(".pair/") && !isPairRuntimeArtifact(file));
  const files = [...new Set([...observed, ...accepted])].sort();
  const expected = files.filter((file) => forecast.has(file));
  const additional = files.filter((file) => !forecast.has(file));
  const chunks = [
    `Cumulative Pair Work patch`,
    `Base: ${base}`,
    `Expected changed files: ${expected.join(", ") || "none"}`,
    `Additional changed files (advisory attribution): ${additional.join(", ") || "none"}`,
    `Complete changed files: ${files.join(", ") || "none"}`,
    "",
  ];
  if (files.length > 0) {
    const tracked = git(root, ["diff", "--binary", base, "--", ...files]);
    if (tracked.status !== 0) {
      throw new Error(
        `cannot build cumulative patch from ${base}: ${(tracked.stderr || tracked.stdout).trim()}`,
      );
    }
    if (tracked.stdout) chunks.push(tracked.stdout);
  }
  for (const file of files) {
    const absolute = path.join(root, file);
    if (!fs.existsSync(absolute)) continue;
    if (git(root, ["ls-files", "--error-unmatch", "--", file]).status === 0)
      continue;
    const created = git(root, [
      "diff",
      "--no-index",
      "--binary",
      "--",
      "/dev/null",
      file,
    ]);
    if (created.stdout) chunks.push(created.stdout);
  }
  const content = redactString(chunks.join("\n"));
  fs.writeFileSync(outputFile, content, { mode: 0o600 });
  return { base, files, expected, additional, path: outputFile, digest: sha256(content) };
}

function finalVerificationCommands(root, parsed) {
  const commands = new Set(
    [
      ...parsed.tasks.map((task) => task.verify),
      ...(parsed.fullVerificationCommands || []),
    ].filter(Boolean),
  );
  const verifyScript = path.join(root, ".pair", "verify.sh");
  if (fs.existsSync(verifyScript) && (fs.statSync(verifyScript).mode & 0o111)) {
    commands.add("./.pair/verify.sh");
  }
  return [...commands];
}

function runFinalVerification(root, parsed) {
  const commands = finalVerificationCommands(root, parsed);
  const results = commands.map((command, index) =>
    runVerificationCommand(
      root,
      command,
      `final gate ${index + 1}/${commands.length}`,
    ),
  );
  return {
    status: results.every((result) => result.status === 0) ? "pass" : "fail",
    commands,
    results,
  };
}

function writeFinalReviewEvidence(root, evidence) {
  const safeEvidence = sanitizeValue(evidence) || {};
  const pairDirectory = path.join(root, ".pair");
  fs.mkdirSync(pairDirectory, { recursive: true, mode: 0o700 });
  fs.writeFileSync(
    path.join(pairDirectory, "final-review.json"),
    `${JSON.stringify(safeEvidence, null, 2)}\n`,
    { mode: 0o600 },
  );
  const findings = safeEvidence.findings.length === 0
    ? "- None."
    : safeEvidence.findings.map((finding) =>
        `- **${finding.severity} (${finding.origin})** ${finding.title} — ${finding.file}:${finding.line}\n  - ${finding.detail}\n  - Failure: ${finding.failure_scenario}\n  - Fix: ${finding.suggestion}`,
      ).join("\n");
  fs.writeFileSync(
    path.join(pairDirectory, "final-review.md"),
    redactString(`# Pair v4 Cumulative Review\n\nPlan digest: \`${safeEvidence.plan_digest}\`\n\nPatch digest: \`${safeEvidence.patch_digest}\`\n\nReviewer: \`${safeEvidence.reviewer}\`\n\n## Summary\n\n${safeEvidence.summary}\n\n## Findings\n\n${findings}\n\n## Verdict\n\n${safeEvidence.verdict}\n`),
    { mode: 0o600 },
  );
}

function finalizePairPlan(root, runtime, options, paths) {
  if (options.legacyV3) return { skipped: true };
  const plan = fs.readFileSync(paths.plan, "utf8");
  if (nextOpenTask(plan)) return { pending: true };
  if (options.dryRun) {
    console.log("pair-loop: dry run — cumulative final gate/review would run after the last task");
    return { dryRun: true };
  }
  const parsed = parsePlan(plan);
  if (parsed.streams.length === 0) return { skipped: true };
  const linkage = readWorkLinkage(root, plan);
  const repoId = repositoryId(root);
  const budgetWorkId = linkage.workId || `plan:${linkage.planDigest}`;
  const ledger = readLedger(paths.ledger);
  const patchFile = path.join(paths.scratch, `final-${linkage.planDigest}.patch`);
  let patch = writeCumulativeReviewPatch(
    root,
    plan,
    ledger,
    linkage,
    repoId,
    patchFile,
  );
  const priorEvidence = readJson(path.join(root, ".pair", "final-review.json"));
  if (
    priorEvidence?.plan_digest === linkage.planDigest &&
    priorEvidence?.patch_digest === patch.digest &&
    priorEvidence?.verdict === "approve" &&
    Array.isArray(priorEvidence.findings) &&
    priorEvidence.findings.length === 0
  ) {
    appendPairEvent(root, {
      event: "work.completed",
      workId: linkage.workId || null,
      planDigest: linkage.planDigest,
      patchDigest: patch.digest,
      evidence: "cached-cumulative-approval",
    });
    console.log(
      `pair-loop: cumulative final review already approves ${patch.digest}`,
    );
    return { approved: true, cached: true };
  }

  const maxReviews = Number.isFinite(options.maxFinalReviews)
    ? options.maxFinalReviews
    : null;
  const reviewCap = finalReviewCapStatus(
    ledger,
    repoId,
    budgetWorkId,
    maxReviews,
  );
  if (maxReviews !== null && reviewCap.overCap) {
    appendPairEvent(root, {
      event: "work.blocked",
      workId: linkage.workId || null,
      phase: "cumulative-review",
      reason: `explicit cumulative review limit ${maxReviews} reached`,
    });
    fail(
      `cumulative review reached the explicitly configured ${maxReviews}-verdict limit for ${linkage.workId || "this plan"}; inspect .pair/final-review.md`,
    );
  }

  const maxGateFailures = process.env.PAIR_MAX_FINAL_GATE_FAILURES
    ? Number(process.env.PAIR_MAX_FINAL_GATE_FAILURES)
    : null;
  const gateCap = finalGateFailureCapStatus(
    ledger,
    repoId,
    budgetWorkId,
    maxGateFailures,
  );
  if (maxGateFailures !== null && gateCap.overCap) {
    appendPairEvent(root, {
      event: "work.blocked",
      workId: linkage.workId || null,
      phase: "cumulative-verification",
      reason: `explicit cumulative verification limit ${maxGateFailures} reached`,
    });
    fail(
      `cumulative verification reached the explicitly configured ${maxGateFailures}-failure limit; inspect the preserved evidence`,
    );
  }

  appendPairEvent(root, {
    event: "work.phase.entered",
    workId: linkage.workId || null,
    phase: "cumulative-verification",
    resume_target: "cumulative-verification",
  });
  const verification = runFinalVerification(root, parsed);
  appendJsonLine(paths.ledger, {
    event: "final-gate.completed",
    repositoryId: repoId,
    workId: budgetWorkId,
    planDigest: linkage.planDigest,
    status: verification.status,
    commands: verification.commands,
    at: new Date().toISOString(),
  });
  if (verification.status !== "pass") {
    appendPairEvent(root, {
      event: "work.correction-needed",
      workId: linkage.workId || null,
      phase: "cumulative-verification",
      resume_target: "cumulative-verification",
      reason: "cumulative verification found a correctable implementation failure",
    });
    fail(
      `cumulative final verification failed; inspect ${verification.results.find((result) => result.status !== 0)?.evidence?.metadata || "the preserved verification evidence"}`,
    );
  }

  // Verification may legitimately generate ignored artifacts. Rebuild the owned
  // patch so the terminal verdict is bound to the exact post-gate implementation.
  patch = writeCumulativeReviewPatch(
    root,
    plan,
    readLedger(paths.ledger),
    linkage,
    repoId,
    patchFile,
  );
  if (options.independentReview === false) {
    const evidence = {
      schema: 1,
      plan_digest: linkage.planDigest,
      patch_digest: patch.digest,
      reviewer: null,
      reviewerSessionId: null,
      classification: "skipped-by-operator",
      verification,
      verdict: "approve",
      recommended_action: "approve",
      summary: "Independent review was explicitly disabled by the operator.",
      findings: [],
    };
    writeFinalReviewEvidence(root, evidence);
    appendJsonLine(paths.ledger, {
      event: "final-review.completed",
      repositoryId: repoId,
      workId: budgetWorkId,
      canonicalWorkId: linkage.workId,
      planDigest: linkage.planDigest,
      patchDigest: patch.digest,
      reviewer: null,
      reviewerSessionId: null,
      classification: evidence.classification,
      usage: null,
      elapsedMs: 0,
      findings: [],
      at: new Date().toISOString(),
    });
    appendPairEvent(root, {
      event: "work.completed",
      workId: linkage.workId || null,
      planDigest: linkage.planDigest,
      patchDigest: patch.digest,
      evidence: "cumulative-verification-approved-independent-review-disabled",
    });
    console.log(`pair-loop: cumulative final verification approved ${patch.digest}; independent review disabled`);
    return { approved: true, cached: false, reviewSkipped: true };
  }
  const finalTask = {
    id: "FINAL",
    text: "cumulative Work implementation",
    risk: "critical",
    acceptanceCriteria: parsed.acceptanceCriteria.map((criterion) => criterion.id),
    files: patch.files,
    consumes: [],
    produces: [],
    defect: "any mapped Acceptance Criterion remains unsatisfied",
    reviewBoundary: "the complete cumulative Work",
  };
  appendPairEvent(root, {
    event: "work.phase.entered",
    workId: linkage.workId || null,
    phase: "cumulative-review",
    resume_target: "cumulative-review",
  });
  const reviewRun = runReview({
    runtime,
    route: {
      model: options.model || "default",
      effort: options.effort || "high",
    },
    root,
    task: finalTask,
    planPath: paths.plan,
    scratchDir: paths.scratch,
    attemptId: `final-${patch.digest.slice(0, 12)}-${reviewCap.reviews + 1}`,
    timeoutMs: Number(process.env.PAIR_FINAL_REVIEW_TIMEOUT_MS || 10 * 60 * 1000),
    dryRun: false,
    reviewSlicePath: patch.path,
    redVerification: verification,
    priorReview: priorEvidence?.findings?.length ? priorEvidence : null,
    cumulative: true,
  });
  const environmentFinding = reviewRun.review.findings.some(
    (finding) => finding.origin === "environment",
  );
  const approved = reviewRun.status === 0 &&
    !environmentFinding &&
    (options.advisoryReview || (
      reviewRun.review.verdict === "approve" &&
      reviewRun.review.findings.length === 0
    ));
  const classification = approved
    ? options.advisoryReview && reviewRun.review.findings.length > 0
      ? "advisory-findings"
      : "approved"
    : reviewRun.status !== 0 || environmentFinding
      ? "environment-failure"
      : "findings";
  const reviewer = `${runtime}/${options.model || "default"}`;
  const evidence = {
    schema: 1,
    plan_digest: linkage.planDigest,
    patch_digest: patch.digest,
    reviewer,
    reviewerSessionId: reviewRun.reviewerSessionId || null,
    classification,
    advisory: options.advisoryReview,
    verification,
    ...reviewRun.review,
  };
  writeFinalReviewEvidence(root, evidence);
  appendJsonLine(paths.ledger, {
    event: "final-review.completed",
    repositoryId: repoId,
    workId: budgetWorkId,
    canonicalWorkId: linkage.workId,
    planDigest: linkage.planDigest,
    patchDigest: patch.digest,
    reviewer,
    reviewerSessionId: reviewRun.reviewerSessionId || null,
    classification,
    usage: reviewRun.usage,
    elapsedMs: reviewRun.elapsedMs,
    findings: reviewRun.review.findings,
    at: new Date().toISOString(),
  });
  if (approved) {
    appendPairEvent(root, {
      event: "work.completed",
      workId: linkage.workId || null,
      planDigest: linkage.planDigest,
      patchDigest: patch.digest,
      reviewerSessionId: reviewRun.reviewerSessionId || null,
      evidence: options.advisoryReview
        ? "cumulative-verification-approved-advisory-review"
        : "cumulative-verification-and-review-approved",
    });
    console.log(
      `pair-loop: cumulative final review approved ${patch.digest}`,
    );
    return { approved: true, cached: false };
  }
  if (maxReviews !== null && reviewCap.reviews + 1 >= maxReviews) {
    appendPairEvent(root, {
      event: "work.blocked",
      workId: linkage.workId || null,
      phase: "cumulative-review",
      reason: `explicit cumulative review limit ${maxReviews} reached without approval`,
    });
    fail(
      `cumulative review did not approve within the explicitly configured ${maxReviews}-verdict limit (see .pair/final-review.md)`,
    );
  }
  if (classification === "environment-failure") {
    appendPairEvent(root, {
      event: "infrastructure.failed",
      workId: linkage.workId || null,
      phase: "cumulative-review",
      resume_target: "cumulative-review",
      cause: "review-infrastructure",
      terminal: false,
    });
    fail(
      `cumulative Review Session infrastructure failed; the complete implementation and verification evidence are preserved for resume (see .pair/final-review.md)`,
    );
  }
  appendPairEvent(root, {
    event: "work.correction-needed",
    workId: linkage.workId || null,
    phase: "cumulative-correction",
    resume_target: "cumulative-correction",
    reason: `material findings remain for patch ${patch.digest}`,
  });
  fail(
    `cumulative review found correctable implementation defects; the complete patch is preserved in the actionable cumulative-correction phase, then bare pair-loop resumes the closure review (see .pair/final-review.md)`,
  );
}

// ---------------------------------------------------------------------------
// HITL mode: with --hitl (or PAIR_HITL=1), a [type:test] task must have its exact
// tests proposed to and approved by the human BEFORE any test is written. The
// proposal is generated by a read-only spawn, persisted to .pair/test-proposal.json
// bound to the task ID and plan contract digest (checkbox progress does not
// invalidate it; editing the task does), and consumed by retries of the same task
// without re-asking. The worker is then constrained to exactly the approved set.
// ---------------------------------------------------------------------------

function testProposalPath(root) {
  return path.join(root, ".pair", "test-proposal.json");
}

function readTestProposal(root, task, plan) {
  const file = testProposalPath(root);
  const proposal = readJson(file);
  if (!proposal || !Array.isArray(proposal.tests)) return null;
  if (
    proposal.taskId !== task.id ||
    proposal.planDigest !== planContractDigest(plan)
  ) {
    fs.rmSync(file, { force: true });
    return null;
  }
  return proposal;
}

function writeTestProposal(root, proposal) {
  fs.mkdirSync(path.join(root, ".pair"), { recursive: true });
  fs.writeFileSync(
    testProposalPath(root),
    `${JSON.stringify(proposal, null, 2)}\n`,
    { mode: 0o600 },
  );
}

function clearTestProposal(root, taskId) {
  const file = testProposalPath(root);
  if (readJson(file)?.taskId === taskId) fs.rmSync(file, { force: true });
}

// selection: 'all' approves everything, 'none' rejects everything, otherwise
// comma-separated 1-based indexes from the printed proposal approve those and
// reject the rest. Pure so approval semantics stay testable.
function applyTestApproval(proposal, selection) {
  const value = String(selection ?? "all")
    .trim()
    .toLowerCase();
  const tests = proposal.tests.map((test) => ({ ...test, approved: false }));
  if (value === "all")
    tests.forEach((test) => {
      test.approved = true;
    });
  else if (value !== "none") {
    for (const raw of value.split(",")) {
      const index = Number.parseInt(raw.trim(), 10);
      if (!Number.isInteger(index) || index < 1 || index > tests.length) {
        throw new Error(
          `invalid test selection "${raw.trim()}"; use all, none, or 1-based indexes like 1,3`,
        );
      }
      tests[index - 1].approved = true;
    }
  }
  return { ...proposal, status: "approved", tests };
}

function printTestProposal(proposal) {
  console.log(
    `pair-loop: task ${proposal.taskId} proposes ${proposal.tests.length} test(s) — review before they are written:`,
  );
  proposal.tests.forEach((test, index) => {
    console.log(
      `  [${index + 1}] ${test.name} — ${test.purpose} (${test.file})`,
    );
  });
  console.log(
    "pair-loop: approve with `pair-loop --approve-tests all` (indexes like 1,3 approve a subset; `none` rejects), then rerun pair-loop.",
  );
}

function proposalPrompt(task, planPath) {
  return `Propose the exact tests-first test set for Pair slice ${task.id} WITHOUT writing or editing any file.\n\n${taskContract(task, planPath)}\n\nRead the Intent Contract, canonical specification, named Repository evidence, relevant callers, and existing tests. Propose the minimum tests that expose only the mapped missing behavior at the declared test boundary. Follow repository naming conventions. For each test return its exact name, one-line behavioral purpose, and one declared test file. Do not propose structure-mirroring tests or behavior outside this slice. Return only the requested structured result.`;
}

function runTestProposal({
  runtime,
  route,
  root,
  task,
  planPath,
  scratchDir,
  timeoutMs,
}) {
  const outputPath = path.join(scratchDir, `${task.id}.test-proposal.json`);
  const rawPath = path.join(
    scratchDir,
    `${task.id}.test-proposal-events.jsonl`,
  );
  const externalSandbox = runtime === "codex" && isNestedCodexSandbox(process.env);
  const snapshot = externalSandbox ? createReviewSnapshot(root, scratchDir) : null;
  const proposalRoot = snapshot?.directory || root;
  const resolvedPlanPath = path.resolve(root, planPath);
  const proposalPlanPath = snapshot && resolvedPlanPath.startsWith(`${path.resolve(root)}${path.sep}`)
    ? path.join(proposalRoot, path.relative(root, resolvedPlanPath))
    : planPath;
  const prompt = proposalPrompt(task, proposalPlanPath);
  let command;
  if (runtime === "codex") {
    const args = [
      "exec",
      "--json",
      "--ephemeral",
      ...(externalSandbox
        ? ["--dangerously-bypass-approvals-and-sandbox", "--skip-git-repo-check"]
        : ["--sandbox", "read-only"]),
      "--output-schema",
      TEST_PROPOSAL_SCHEMA_PATH,
      "--output-last-message",
      outputPath,
    ];
    if (route.model && route.model !== "default")
      args.push("--model", route.model);
    if (route.effort && route.effort !== "default")
      args.push("-c", `model_reasoning_effort="${route.effort}"`);
    args.push(prompt);
    command = { file: "codex", args, cwd: proposalRoot };
  } else {
    command = {
      file: "claude",
      args: [
        "-p",
        prompt,
        "--output-format",
        "json",
        "--no-session-persistence",
        "--permission-mode",
        "dontAsk",
        "--disallowedTools",
        "Edit,Write,NotebookEdit,Task",
        "--json-schema",
        JSON.stringify(readJson(TEST_PROPOSAL_SCHEMA_PATH)),
        "--model",
        route.model,
        "--effort",
        route.effort === "default" ? "medium" : route.effort,
      ],
      cwd: root,
    };
  }
  const result = runCommand(
    command,
    rawPath,
    timeoutMs,
    `test proposal ${task.id}`,
  );
  const snapshotMutated = snapshot && treeDigest(snapshot.directory) !== snapshot.digest;
  const sourceMutated = snapshot
    && repositoryDigest(root, scratchDir) !== snapshot.sourceDigest;
  const envelope = readJsonFromString(result.stdout || "");
  const candidate = envelope?.structured_output || envelope?.result || envelope;
  const parsed =
    runtime === "codex"
      ? readJson(outputPath)
      : typeof candidate === "string"
        ? readJsonFromString(candidate)
        : candidate;
  const tests = Array.isArray(parsed?.tests)
    ? parsed.tests.filter(
        (test) => test && typeof test === "object" && test.name && test.file,
      )
    : [];
  if (snapshot) fs.rmSync(snapshot.directory, { recursive: true, force: true });
  return {
    status: snapshotMutated || sourceMutated ? 1 : (result.status ?? 1),
    tests,
    usage: parseRuntimeUsage(runtime, result.stdout || ""),
    elapsedMs: result.elapsedMs ?? null,
  };
}

// Minimal synchronous TTY prompt (no dependencies): the loop is spawnSync-based,
// so approval on a terminal blocks inline instead of forcing an exit/rerun cycle.
function syncPromptTTY(question) {
  process.stdout.write(question);
  const buffer = Buffer.alloc(256);
  const bytes = fs.readSync(process.stdin.fd, buffer, 0, 256, null);
  return buffer.toString("utf8", 0, bytes).trim();
}

function promptApprovalTTY(proposal) {
  printTestProposal(proposal);
  const tests = proposal.tests.map((test) => ({
    ...test,
    approved: /^y(es)?$/i.test(
      syncPromptTTY(`  approve [${test.name}]? [y/N] `),
    ),
  }));
  return { ...proposal, status: "approved", tests };
}

// Returns {action:'proceed', approvedTests} when the worker may run, or
// {action:'await'} when the loop must pause for human approval. The generate
// parameter is injectable for tests; production uses the read-only proposal spawn.
function hitlGate(
  { root, plan, task, runtime, route, paths, options },
  generate = runTestProposal,
) {
  const hasPairLiteTests = !options.legacyV3 &&
    task.type !== "docs" &&
    (task.testFiles || []).length > 0;
  if (
    !options.hitl ||
    (!hasPairLiteTests && !["cycle", "red-contract"].includes(task.tddMode))
  )
    return { action: "proceed", approvedTests: null };
  if (options.dryRun) {
    const existing = readTestProposal(root, task, plan);
    return {
      action: "proceed",
      approvedTests: existing?.tests?.filter((test) => test.approved) || null,
    };
  }
  let proposal = readTestProposal(root, task, plan);
  if (!proposal) {
    const generated = generate({
      runtime,
      route,
      root,
      task,
      planPath: paths.plan,
      scratchDir: paths.scratch,
      timeoutMs: Number(process.env.PAIR_PROPOSAL_TIMEOUT_MS || 10 * 60 * 1000),
    });
    if (generated.status !== 0 || generated.tests.length === 0) {
      fail(`task ${task.id} test proposal failed; see ${paths.scratch}`);
    }
    proposal = {
      schema: 1,
      taskId: task.id,
      planDigest: planContractDigest(plan),
      status: "proposed",
      tests: generated.tests.map((test) => ({ ...test, approved: false })),
    };
    writeTestProposal(root, proposal);
    if (generated.usage) {
      appendJsonLine(paths.ledger, {
        event: "test-proposal.generated",
        taskId: task.id,
        routeId: route.id,
        usage: generated.usage,
        elapsedMs: generated.elapsedMs,
        at: new Date().toISOString(),
      });
    }
  }
  if (proposal.status !== "approved") {
    if (process.stdin.isTTY && process.stdout.isTTY) {
      proposal = promptApprovalTTY(proposal);
      writeTestProposal(root, proposal);
    } else {
      printTestProposal(proposal);
      return { action: "await" };
    }
  }
  const approvedTests = proposal.tests.filter((test) => test.approved);
  if (approvedTests.length === 0) {
    fail(
      `task ${task.id} has no approved tests; revise the plan task or delete .pair/test-proposal.json to repropose`,
    );
  }
  return { action: "proceed", approvedTests };
}

function completeTask(planPath, task) {
  const lines = fs.readFileSync(planPath, "utf8").split(/\r?\n/);
  const index = task.line - 1;
  if (!lines[index]?.match(/^\s*[-*]\s+\[[ -]\]/))
    throw new Error(`Task ${task.id} moved while the attempt was running`);
  lines[index] = lines[index].replace(/\[[ -]\]/u, "[x]");

  // A criterion closes automatically once every Stream task mapped to it is
  // complete. This keeps criteria as evidence/status and prevents the old runner
  // from synthesizing an extra model invocation for each unchecked AC checkbox.
  const updated = parsePlan(lines.join("\n"));
  for (const criterionId of task.acceptanceCriteria || []) {
    const mappedTasks = updated.tasks.filter((candidate) =>
      candidate.acceptanceCriteria.includes(criterionId),
    );
    if (mappedTasks.length === 0 || !mappedTasks.every((candidate) => candidate.checked))
      continue;
    const criterion = updated.acceptanceCriteria.find(
      (candidate) => candidate.id === criterionId,
    );
    const criterionIndex = (criterion?.line || 0) - 1;
    if (criterionIndex >= 0 && /^\s*[-*]\s+\[ \]/.test(lines[criterionIndex])) {
      lines[criterionIndex] = lines[criterionIndex].replace("[ ]", "[x]");
    }
  }
  fs.writeFileSync(planPath, lines.join("\n"));
}

function activateTask(planPath, task) {
  const lines = fs.readFileSync(planPath, "utf8").split(/\r?\n/u);
  const index = task.line - 1;
  if (lines[index]?.match(/^\s*[-*]\s+\[-\]/u)) return false;
  if (!lines[index]?.match(/^\s*[-*]\s+\[ \]/u)) {
    throw new Error(`Task ${task.id} moved while the attempt was opening`);
  }
  lines[index] = lines[index].replace("[ ]", "[-]");
  fs.writeFileSync(planPath, lines.join("\n"));
  return true;
}

function queueTask(planPath, task) {
  const lines = fs.readFileSync(planPath, "utf8").split(/\r?\n/u);
  const index = task.line - 1;
  if (lines[index]?.match(/^\s*[-*]\s+\[ \]/u)) return false;
  if (!lines[index]?.match(/^\s*[-*]\s+\[-\]/u)) {
    throw new Error(`Task ${task.id} moved while its attempt was being discarded`);
  }
  lines[index] = lines[index].replace("[-]", "[ ]");
  fs.writeFileSync(planPath, lines.join("\n"));
  return true;
}

// Preflight: check every environmental invariant the loop depends on and report
// ok/warn/fail lines instead of letting a broken link surface an hour later as a
// generic environment-failure. Returns the number of failing checks.
function runDoctor(root, options = {}) {
  const results = [];
  const report = (level, name, detail) => results.push({ level, name, detail });
  let doctorWorkId = null;

  report("ok", "git repository", root);
  const freshness = freshnessProjection(root);
  report(
    freshness.warning ? "warn" : "ok",
    "Freshness Gate",
    freshness.warning || "no registered Agent Conversation requires a handover",
  );

  const pairPlan = path.join(root, ".pair", "plan.md");
  const loopPlan = path.join(root, ".claude-loop.md");
  const plan = fs.existsSync(pairPlan)
    ? pairPlan
    : fs.existsSync(loopPlan)
      ? loopPlan
      : null;
  if (!plan)
    report(
      "fail",
      "plan",
      "no .pair/plan.md or .claude-loop.md; promote a plan first",
    );
  else if (plan === pairPlan && process.env.PAIR_SKIP_PLAN_VALIDATION !== "1") {
    const validation = childProcess.spawnSync(
      process.execPath,
      [path.join(SCRIPT_DIR, "validate-plan"), plan],
      { cwd: root, encoding: "utf8" },
    );
    if (validation.status === 0)
      report("ok", "plan", ".pair/plan.md validates");
    else
      report(
        "fail",
        "plan",
        (validation.stdout || validation.stderr || "validation failed")
          .trim()
          .split("\n")
          .slice(0, 3)
          .join(" | "),
      );
  } else report("ok", "plan", `${path.relative(root, plan)} present`);
  if (plan === pairPlan) {
    try {
      doctorWorkId = readWorkIdentity(root, fs.readFileSync(plan, "utf8")).workId || null;
    } catch {
      // readWorkLinkage below owns the actionable contract diagnostic.
    }
    try {
      const linkage = readWorkLinkage(root, fs.readFileSync(plan, "utf8"));
      doctorWorkId = linkage.workId || null;
      report(
        "ok",
        "work linkage",
        linkage.workId
          ? `Work ${linkage.workId}`
          : "plain plan (no canonical spec mirror)",
      );
    } catch (error) {
      if (
        planNeedsApproval(error) &&
        process.env.PAIR_AUTO_PLAN_CHALLENGE !== "0"
      ) {
        report(
          "warn",
          "work linkage",
          "current plan approval is pending and will be automatically challenged by the next Pair run",
        );
      } else {
        report("fail", "work linkage", error.message);
      }
    }
  }

  const codex = commandExists("codex");
  const claude = commandExists("claude");
  if (!codex && !claude)
    report("fail", "runtime", "neither codex nor claude is on PATH");
  else
    report(
      "ok",
      "runtime",
      `${[codex && "codex", claude && "claude"].filter(Boolean).join(", ")} available`,
    );

  if (
    (process.env.PATH || "")
      .split(path.delimiter)
      .some((entry) => entry.includes("cmux-cli-shims"))
  ) {
    report(
      "warn",
      "PATH shims",
      "cmux-cli-shims on PATH; stripped automatically for spawned runtimes",
    );
  }
  const nested = NESTED_SESSION_ENV_KEYS.filter((key) => process.env[key]);
  if (nested.length > 0)
    report(
      "warn",
      "session env",
      `${nested.join(", ")} set; cleared automatically for spawned runtimes`,
    );
  if (isNestedCodexSandbox()) {
    if (options.runtime === "claude") {
      report(
        "ok",
        "nested Codex sandbox",
        "Claude was selected explicitly; no nested Codex sandbox is required",
      );
    } else {
      report(
        "ok",
        "nested Codex sandbox",
        "Codex delegates containment to the active external sandbox; read-only gates use mutation-checked disposable repository snapshots",
      );
    }
  }

  const activeLoop = readJson(path.join(root, ".pair", "active-loop.json"));
  if (activeLoop?.pid) {
    report(
      "warn",
      "active loop",
      processAlive(activeLoop.pid)
        ? `pair-loop already running in process ${activeLoop.pid}`
        : "stale marker from a dead run; replaced on the next run",
    );
  }
  if (fs.existsSync(path.join(root, ".pair", "active-attempt.json"))) {
    report(
      "warn",
      "active attempt",
      "unresolved attempt; reconciled on the next run (finish an inline one with --complete)",
    );
  }
  const restorationFailure = readJson(restorationFailurePath(root));
  if (restorationFailure) {
    report(
      "fail",
      "restoration",
      `${restorationFailure.reason || "unresolved restoration failure"}${
        restorationFailure.remaining_paths?.length
          ? ` (${restorationFailure.remaining_paths.join(", ")})`
          : ""
      }`,
    );
  }

  let boundLegacyLedger = null;
  if (!process.env.PAIR_DATA_DIR && plan === pairPlan) {
    try {
      const linkage = readWorkIdentity(root, fs.readFileSync(plan, "utf8"));
      const binding = readJson(
        path.join(root, ".pair", "ledger-bindings.json"),
      )?.bindings?.[`work:${linkage.workId}`];
      boundLegacyLedger = binding?.legacy_ledger ||
        (binding?.ledger && !String(binding.ledger).startsWith(".pair/")
          ? binding.ledger
          : null);
    } catch {
      // The authoritative linkage check above reports any real error. Legacy
      // discovery stays advisory so it cannot mask the contract failure.
    }
  }
  const eventStore = pairStatePaths(root, doctorWorkId).events;
  try {
    fs.mkdirSync(path.dirname(eventStore), { recursive: true, mode: 0o700 });
    fs.accessSync(path.dirname(eventStore), fs.constants.W_OK);
    report("ok", "event store", path.relative(root, eventStore));
  } catch {
    report("fail", "event store", `${path.relative(root, eventStore)} is not writable`);
  }

  const legacyLedger = process.env.PAIR_DATA_DIR
    ? path.join(process.env.PAIR_DATA_DIR, "attempts.jsonl")
    : boundLegacyLedger;
  if (legacyLedger) {
    try {
      fs.accessSync(legacyLedger, fs.constants.R_OK);
      report("ok", "legacy history", `${legacyLedger} is readable for one-time import`);
    } catch {
      report(
        "warn",
        "legacy history",
        "configured history is unavailable; Pair v4 continues with repository-local state",
      );
    }
  }

  if (!commandExists("jq"))
    report(
      "warn",
      "jq",
      "not on PATH; the stop-gate hook stays inert without it",
    );
  const verifyScript = path.join(root, ".pair", "verify.sh");
  if (
    fs.existsSync(verifyScript) &&
    !(fs.statSync(verifyScript).mode & 0o111)
  ) {
    report(
      "warn",
      "verify.sh",
      "present but not executable; verification falls back to replaying worker-reported commands",
    );
  }

  for (const { level, name, detail } of results)
    console.log(`pair-doctor: ${level.padEnd(4)} ${name} — ${detail}`);
  const fails = results.filter((item) => item.level === "fail").length;
  const warns = results.filter((item) => item.level === "warn").length;
  console.log(
    `pair-doctor: ${results.length - fails - warns} ok, ${warns} warn, ${fails} fail`,
  );
  return fails;
}

// Only low-risk, local-scope work is worth delegating to a cold headless worker under
// --inline; the ledger shows warm-context inline implementation beats cold spawns on
// everything harder (feature/high: 25% accepted at the strong tier, rewritten inline).
function isDelegable(_task) {
  return false;
}

function inlineBrief(task, planPath, priorReview, approvedTests, phase = "green") {
  const body = (phase === "red"
    ? redWorkerPrompt(task, planPath, approvedTests, priorReview)
    : workerPrompt(task, planPath, priorReview, approvedTests, phase === "slice"))
    .replace("\nReturn only the requested structured result.", "");
  const next = phase === "red"
    ? "write only the RED tests, run the exact RED command, then run bare `pair-loop`; it will independently replay RED and hand back the GREEN phase (`--complete` remains a compatibility alias)"
    : phase === "slice"
      ? "finish the complete tests-first slice, run the exact verification, then run bare `pair-loop` for deterministic replay, conditional review, classification, and repository evidence (`--complete` remains a compatibility alias)"
      : "finish the GREEN implementation, run the exact verification, then run bare `pair-loop` for replay, independent review, classification, and repository evidence (`--complete` remains a compatibility alias)";
  return `--- INLINE TASK BRIEF (${phase.toUpperCase()}) ---\n${body}\nWhen done: ${next}.\n--- END BRIEF ---`;
}

function enterAttemptPhase(paths, attempt, phase, checkpoint = {}) {
  if (!fs.existsSync(paths.active)) return attempt;
  const current = readJson(paths.active);
  if (!current || current.attemptId !== attempt.attemptId) return attempt;
  const updated = sanitizeValue({
    ...current,
    ...checkpoint,
    phase,
    resume_target: phase,
  });
  writePrivateJson(paths.active, updated);
  appendJsonLine(paths.ledger, {
    event: "phase.entered",
    attemptId: attempt.attemptId,
    taskId: attempt.taskId,
    workId: attempt.workId || null,
    planDigest: attempt.planDigest || null,
    phase,
    resume_target: phase,
    patchDigest: checkpoint.patchDigest || null,
    reviewerSessionId: checkpoint.reviewerSessionId || null,
  });
  Object.assign(attempt, updated);
  return updated;
}

function resumeActiveAttempt(root, runtime, options, paths) {
  const active = readJson(paths.active);
  if (!active?.attemptId) return { done: false };
  const plan = fs.readFileSync(paths.plan, "utf8");
  const task = parsePlan(plan).tasks.find((item) => item.id === active.taskId);
  if (!task) fail(`task ${active.taskId} no longer exists in the plan`);
  if (["verifying", "reviewing"].includes(active.phase)) {
    return inlineComplete(root, runtime, options, paths);
  }
  if (active.phase !== "implementing") {
    fail(
      `attempt ${active.attemptId} is paused at ${active.phase}; use pair-task --status for its resume target`,
    );
  }
  const implementationChanges = changedPathsSinceSnapshot(root, active.snapshot)
    .filter((file) => !isPairRuntimeArtifact(file));
  if (implementationChanges.length > 0) {
    if (active.awaitingPatchDigest) {
      const checkpointFile = path.join(
        pairStatePaths(root, active.workId || null).attempts,
        active.attemptId,
        "complete.patch",
      );
      if (fs.existsSync(checkpointFile)) {
        writeReviewSlicePatch(root, task, active.snapshot, checkpointFile);
        const currentDigest = sha256(fs.readFileSync(checkpointFile));
        if (currentDigest === active.awaitingPatchDigest) {
          console.log(
            `pair-v4: attempt ${active.attemptId} is waiting for a local correction; the complete patch is unchanged`,
          );
          console.log(
            inlineBrief(
              task,
              paths.plan,
              readJson(path.join(root, ".pair", "review.json")),
              null,
              "slice",
            ),
          );
          return { done: false, inlineHandoff: true, resumed: true };
        }
      }
    }
    console.log(
      `pair-v4: detected ${implementationChanges.length} implementation change(s); advancing attempt ${active.attemptId} to verification`,
    );
    return inlineComplete(root, runtime, options, paths);
  }
  console.log(
    inlineBrief(
      task,
      paths.plan,
      readJson(path.join(root, ".pair", "review.json")),
      null,
      !options.legacyV3 && task.tddMode !== "red-contract"
        ? "slice"
        : ["cycle", "red-contract"].includes(task.tddMode)
          ? "red"
          : "green",
    ),
  );
  return { done: false, inlineHandoff: true, resumed: true };
}

// Shared verify -> review -> classify -> record -> apply pipeline for both delegated
// worker runs and inline coordinator completions. options.dryRun only stubs the
// independent review (used by --complete tests); everything else runs for real.
function assessAttempt({
  root,
  runtime,
  options,
  paths,
  task,
  attempt,
  prior,
  snapshot,
  route,
  worker,
  workerRun,
  workerError,
  redPhase = null,
  greenSnapshot = null,
}) {
  let verification;
  const resumesReview = attempt.phase === "reviewing" && attempt.verification?.status;
  if (resumesReview) {
    verification = attempt.verification;
  } else {
    enterAttemptPhase(paths, attempt, "verifying");
    try {
      verification = verify(root, task, worker, snapshot, greenSnapshot);
    } catch (error) {
      const marker = recordRestorationFailure(root, task, attempt, error);
      fail(
        `task ${task.id} snapshot verification failed and further attempts are blocked: ${marker.reason}; inspect ${restorationFailurePath(root)}`,
      );
    }
  }
  const verificationInfrastructureFailure = verification.status === "fail" && (
    Boolean(verification.termination) ||
    Boolean(verification.signal) ||
    verification.exit_status === null ||
    [126, 127].includes(verification.exit_status) ||
    (verification.exit_statuses || []).some((status) => status === null || [126, 127].includes(status))
  );
  if (verificationInfrastructureFailure) {
    enterAttemptPhase(paths, attempt, "verifying", {
      verification: {
        status: "infrastructure-failure",
        command: verification.command,
        termination: verification.termination || null,
        signal: verification.signal || null,
        evidence: verification.evidence || null,
        ownership: verification.ownership || null,
      },
    });
    appendJsonLine(paths.ledger, {
      event: "infrastructure.failed",
      attemptId: attempt.attemptId,
      taskId: task.id,
      workId: attempt.workId || null,
      planDigest: attempt.planDigest || null,
      phase: "verifying",
      resume_target: "verifying",
      cause: verification.termination || "verification-launch",
      terminal: false,
    });
    console.error(
      `pair-v4: verification infrastructure failed for task ${task.id}; implementation is preserved and the same attempt will resume at verifying`,
    );
    return { done: false, action: "resume-verification", recoverable: true };
  }
  const attemptEvidenceDirectory = path.join(
    pairStatePaths(root, attempt.workId || null).attempts,
    attempt.attemptId,
  );
  fs.mkdirSync(attemptEvidenceDirectory, { recursive: true, mode: 0o700 });
  const reviewSlice = writeReviewSlicePatch(
    root,
    task,
    snapshot,
    path.join(attemptEvidenceDirectory, "complete.patch"),
  );
  const reviewSliceDigest = sha256(fs.readFileSync(reviewSlice.path));
  const priorReview = ["retry-review", "local-fix"].includes(prior.at(-1)?.action)
    ? prior.at(-1)?.review || null
    : null;
  const eligibleForReview =
    workerRun.status === 0 &&
    worker.status === "completed" &&
    verification.status === "pass";
  if (eligibleForReview) {
    enterAttemptPhase(paths, attempt, "reviewing", {
      verification: {
        status: verification.status,
        command: verification.command,
        ownership: verification.ownership || null,
      },
      reviewSlice: {
        path: reviewSlice.path,
        changed: reviewSlice.changed,
      },
      patchDigest: reviewSliceDigest,
    });
  }
  const taskReviewRequired = eligibleForReview && shouldRunTaskReview(task, options);
  const reviewRun =
    taskReviewRequired
      ? runReview({
          runtime,
          route,
          root,
          task,
          planPath: paths.plan,
          scratchDir: paths.scratch,
          attemptId: attempt.attemptId,
          timeoutMs: Number(
            process.env.PAIR_REVIEW_TIMEOUT_MS || 10 * 60 * 1000,
          ),
          dryRun: options.dryRun === true,
          reviewSlicePath: reviewSlice.path,
          redVerification: redPhase?.verification || null,
          priorReview,
        })
      : eligibleForReview
        ? {
            status: 0,
            review: {
              verdict: "approve",
              recommended_action: "approve",
              summary: "Pair-lite skipped per-slice model review; cumulative final review remains required.",
              findings: [],
            },
            usage: null,
            skipped: true,
          }
      : {
          status: workerRun.status === 0 && worker.status === "completed" ? 0 : 1,
          review: {
            verdict: "fix-needed",
            recommended_action: "approve",
            summary: verification.status === "fail"
              ? "independent review skipped because coordinator verification failed"
              : "worker did not complete",
            findings: [],
          },
          usage: null,
        };
  const anchorRun =
    reviewRun.status === 0 &&
    !options.dryRun &&
    !reviewRun.skipped &&
    shouldRunAnchorReview(attempt.attemptId, task, reviewRun.review)
      ? runReview({
          runtime,
          route,
          root,
          task,
          planPath: paths.plan,
          scratchDir: paths.scratch,
          attemptId: `${attempt.attemptId}.anchor`,
          timeoutMs: Number(
            process.env.PAIR_REVIEW_TIMEOUT_MS || 10 * 60 * 1000,
          ),
          dryRun: false,
          anchor: true,
          reviewSlicePath: reviewSlice.path,
          redVerification: redPhase?.verification || null,
          priorReview,
        })
      : null;
  const activeReviewerSessionId = anchorRun?.reviewerSessionId || reviewRun.reviewerSessionId || null;
  if (eligibleForReview && activeReviewerSessionId) {
    enterAttemptPhase(paths, attempt, "reviewing", {
      reviewerSessionId: activeReviewerSessionId,
    });
  }
  const failedReviewRun = taskReviewRequired && (reviewRun.status !== 0 || (anchorRun && anchorRun.status !== 0));
  if (failedReviewRun) {
    appendJsonLine(paths.ledger, {
      event: "infrastructure.failed",
      attemptId: attempt.attemptId,
      taskId: task.id,
      workId: attempt.workId || null,
      planDigest: attempt.planDigest || null,
      phase: "reviewing",
      resume_target: "reviewing",
      cause: "review-infrastructure",
      terminal: false,
    });
    console.error(
      `pair-v4: Review Session failed for task ${task.id}; verified work is preserved and the same attempt will resume at reviewing`,
    );
    return { done: false, action: "resume-review", recoverable: true };
  }
  const anchorDisagrees =
    anchorRun?.review &&
    (anchorRun.review.verdict !== "approve" ||
      anchorRun.review.recommended_action !== "approve");
  const effectiveReview = anchorDisagrees ? anchorRun.review : reviewRun.review;
  const ownership = redPhase?.verification?.ownership?.status === "fail"
    ? redPhase.verification.ownership
    : verification.ownership || null;
  const outcome = classifyOutcome({
    workerStatus: worker.status,
    workerBlocker: worker.blocker,
    verification: verification.status,
    ownership,
    findings: options.advisoryReview ? [] : effectiveReview.findings || [],
    priorRetryCounts: options.legacyV3
      ? attemptCapStatus(prior, options.maxAttempts).retryCounts
      : {},
    runtimeStatus: workerRun.status ?? 1,
    reviewStatus: anchorRun ? (anchorRun.status ?? 1) : (reviewRun.status ?? 1),
    recommendedAction: effectiveReview.recommended_action,
    workerParseError: worker.parseError === true,
  });
  const recordedReview = options.advisoryReview
    ? { ...effectiveReview, advisory: true, remediation_required: false }
    : outcome.action === "retry-context"
    ? { ...effectiveReview, retry_context: worker.blocker }
    : outcome.action === "retry-ownership"
      ? {
          ...effectiveReview,
          ownership,
          retry_context: [
            `The previous attempt changed files outside the declared Review Slice: ${(ownership?.outside || []).join(", ")}.`,
            "Do not touch those paths on this retry.",
            "If any listed path is required to satisfy the task, return blocked with a blocker beginning 'incorrect-plan:' instead of expanding ownership.",
          ].join(" "),
        }
      : effectiveReview;
  writeReviewFiles(root, recordedReview);
  const workerUsage = parseRuntimeUsage(runtime, workerRun.stdout || "");
  const distinctRedUsage = task.tddMode === "cycle" ? redPhase?.usage : null;
  const measuredCosts = [
    distinctRedUsage?.costUsd,
    workerUsage.costUsd,
    reviewRun.usage?.costUsd,
    anchorRun?.usage?.costUsd,
  ].filter(Number.isFinite);
  const totalCost =
    measuredCosts.length > 0
      ? measuredCosts.reduce((sum, value) => sum + value, 0)
      : (route.expectedCost ?? null);
  const completed = {
    event: "attempt.completed",
    ...attempt,
    status: "completed",
    finishedAt: new Date().toISOString(),
    elapsedMs: Math.max(
      0,
      Date.now() - new Date(attempt.startedAt || Date.now()).getTime(),
    ),
    worker,
    redPhase: redPhase
      ? {
          worker: redPhase.worker,
          verification: redPhase.verification,
        }
      : null,
    verification,
    review: recordedReview,
    primaryReview: reviewRun.review,
    anchorReview: anchorRun?.review || null,
    reviewCalibration: anchorRun
      ? {
          sampled: true,
          missedFindings: Math.max(
            0,
            (anchorRun.review.findings || []).length -
              (reviewRun.review.findings || []).length,
          ),
        }
      : { sampled: false, missedFindings: 0 },
    usage: {
      worker: workerUsage,
      redWorker: distinctRedUsage || null,
      reviewer: reviewRun.usage,
      anchorReviewer: anchorRun?.usage || null,
    },
    totalCost,
    costSource: measuredCosts.length > 0 ? "runtime" : "route-estimate",
    success: outcome.disposition === "accepted",
    valid:
      workerRun.status === 0 &&
      (!redPhase || (redPhase.run.status === 0 && redPhase.verification.status === "pass")) &&
      verification.status === "pass" &&
      reviewRun.status === 0 &&
      (!anchorRun || anchorRun.status === 0),
    runtimeError: workerError || null,
    ...outcome,
  };

  if (!options.legacyV3 && outcome.disposition !== "accepted") {
    const hardBoundary = verification.ownership?.hardBoundaries?.length > 0;
    const requiresMaterialDecision = hardBoundary ||
      outcome.action === "return-to-promotion" ||
      outcome.action === "stop" ||
      recordedReview.findings?.some((finding) => finding.origin === "plan");
    const resumePhase = requiresMaterialDecision
      ? "blocked"
      : outcome.action === "retry-review"
        ? "reviewing"
        : "implementing";
    enterAttemptPhase(paths, attempt, resumePhase, {
      verification,
      review: recordedReview,
      reviewSlice: {
        path: reviewSlice.path,
        changed: reviewSlice.changed,
      },
      patchDigest: reviewSliceDigest,
      awaitingPatchDigest: resumePhase === "implementing" ? reviewSliceDigest : null,
      blockedReason: requiresMaterialDecision ? outcome.cause : null,
    });
    appendJsonLine(paths.ledger, {
      ...completed,
      event: "attempt.outcome",
      status: "active",
      terminal: false,
      phase: resumePhase,
      resume_target: resumePhase,
      patchDigest: reviewSliceDigest,
    });
    const boundaryDetail = hardBoundary
      ? ` Hard boundary: ${verification.ownership.hardBoundaries.join(", ")}.`
      : "";
    console.log(
      requiresMaterialDecision
        ? `pair-v4: attempt ${attempt.attemptId} is blocked on a material decision at ${resumePhase}; all repository changes and evidence are preserved.${boundaryDetail}`
        : `pair-v4: attempt ${attempt.attemptId} needs a local correction; all repository changes, green evidence, and Review Session context are preserved on the same attempt`,
    );
    return {
      done: false,
      action: outcome.action,
      recoverable: !requiresMaterialDecision,
      blocked: requiresMaterialDecision,
    };
  }

  appendJsonLine(paths.ledger, completed);
  fs.rmSync(paths.active, { force: true });

  // Any outcome that retries or redoes the task starts the next attempt from a clean
  // canvas: keep work only when it is accepted or locally fixable in place.
  const revertActions = new Set([
    "escalate",
    "return-to-promotion",
    "retry-context",
    "retry-infrastructure",
    "retry-ownership",
    "retry-verification",
    "retry-review",
    "retry-stronger",
  ]);
  if (options.legacyV3 && revertActions.has(outcome.action)) {
    try {
      revertToSnapshot(
        root,
        snapshot,
        path.join(paths.scratch, `${attempt.attemptId}.rejected.patch`),
      );
    } catch (error) {
      const marker = recordRestorationFailure(root, task, attempt, error);
      fail(
        `task ${task.id} restoration failed and further attempts are blocked: ${marker.reason}; inspect ${restorationFailurePath(root)}`,
      );
    }
    console.log(
      `pair-loop: task ${task.id} worktree restored to its pre-attempt state; rejected work saved to scratch`,
    );
  }

  if (outcome.action === "complete-task") {
    completeTask(paths.plan, task);
    clearTestProposal(root, task.id);
  }
  if (outcome.action !== "stop") {
    cleanupWorktreeSnapshots(snapshot, greenSnapshot);
  }
  console.log(
    `pair-loop: task ${task.id} -> ${outcome.disposition} (${outcome.action})`,
  );
  if (outcome.action === "stop")
    fail(`task ${task.id} stopped: ${outcome.cause}`);
  if (outcome.action === "return-to-promotion")
    fail(`task ${task.id} stopped: ${outcome.cause}; return to pair promotion without editing the approved plan in place`);
  return { done: false, action: outcome.action };
}

// Finish an inline attempt: the coordinator implemented the task in-session, and this
// replays its verification, runs the independent review, classifies, and records —
// the same evidence pipeline a delegated worker gets.
function inlineComplete(root, runtime, options, paths) {
  const active = readJson(paths.active);
  if (!active?.attemptId) fail("no attempt is awaiting completion");
  if (!["inline", "inline-red", "inline-red-contract", "inline-green"].includes(active.mode))
    fail(
      "the active attempt is a delegated run; it is recovered automatically by the next pair-loop run",
    );
  const plan = fs.readFileSync(paths.plan, "utf8");
  const task = parsePlan(plan).tasks.find((item) => item.id === active.taskId);
  if (!task) fail(`task ${active.taskId} no longer exists in the plan`);
  if (task.checked)
    fail(`task ${active.taskId} is already checked; nothing to complete`);

  if (active.mode === "inline-red" || active.mode === "inline-red-contract") {
    const redVerification = verifyRed(root, task, active.snapshot);
    if (redVerification.status === "pass") {
      const redWorker = {
        status: "completed",
        summary: "RED phase implemented inline by the coordinator session",
        files_changed: task.testFiles,
        tests: [{ command: task.redVerify, status: "fail" }],
        blocker: null,
      };
      if (active.mode === "inline-red-contract") {
        return assessAttempt({
          root,
          runtime,
          options,
          paths,
          task,
          attempt: active,
          prior: taskHistory(readLedger(paths.ledger), task.id, active.repositoryId, active.workId, active.planDigest),
          snapshot: active.snapshot,
          route: { id: active.routeId, runtime: active.runtime, model: active.model, effort: active.effort, strength: 4 },
          worker: redWorker,
          workerRun: { status: 0, stdout: "" },
          workerError: "",
          redPhase: { worker: redWorker, run: { status: 0, stdout: "" }, usage: null, verification: redVerification },
        });
      }
      const greenSnapshot = snapshotWorktree(root, paths.scratch);
      const next = {
        ...active,
        mode: "inline-green",
        redPhase: {
          worker: redWorker,
          run: { status: 0, stdout: "" },
          usage: null,
          verification: redVerification,
        },
        greenSnapshot,
      };
      writePrivateJson(paths.active, next);
      console.log(`pair-loop: task ${task.id} RED contract reproduced; continuing to GREEN`);
      console.log(inlineBrief(
        task,
        paths.plan,
        readJson(path.join(root, ".pair", "review.json")),
        readTestProposal(root, task, plan)?.tests?.filter((test) => test.approved),
        "green",
      ));
      return { action: "continue-green" };
    }
    const blocked = {
      status: "blocked",
      summary: "declared RED contract was not reproduced",
      files_changed: task.testFiles,
      tests: [{ command: task.redVerify, status: "fail" }],
      blocker: redVerification.ownership?.status === "fail"
        ? `verification-defect: ${redVerification.output}`
        : `incorrect-plan: ${redVerification.output}`,
    };
    return assessAttempt({
      root,
      runtime,
      options,
      paths,
      task,
      attempt: active,
      prior: taskHistory(readLedger(paths.ledger), task.id, active.repositoryId, active.workId, active.planDigest),
      snapshot: active.snapshot,
      route: { id: active.routeId, runtime: active.runtime, model: active.model, effort: active.effort, strength: 4 },
      worker: blocked,
      workerRun: { status: 0, stdout: "" },
      workerError: "",
      redPhase: { worker: blocked, run: { status: 0, stdout: "" }, usage: null, verification: redVerification },
    });
  }
  const prior = taskHistory(
    readLedger(paths.ledger),
    task.id,
    active.repositoryId,
    active.workId,
    active.planDigest,
  );
  const worker = {
    status: "completed",
    summary: "implemented inline by the coordinator session",
    files_changed: task.files,
    tests: task.verify ? [{ command: task.verify, status: "pass" }] : [],
  };
  const route = {
    id: active.routeId,
    runtime: active.runtime,
    model: active.model,
    effort: active.effort,
    strength: 4,
  };
  const result = assessAttempt({
    root,
    runtime,
    options,
    paths,
    task,
    attempt: active,
    prior,
    snapshot: active.snapshot,
    route,
    worker,
    workerRun: { status: 0, stdout: "" },
    workerError: "",
    redPhase: active.redPhase || null,
    greenSnapshot: active.greenSnapshot || null,
  });
  if (result.action === "complete-task")
    console.log(`pair-loop: task ${task.id} completed inline and accepted`);
  return result;
}

function buildWorkerPhase({ runtime, route, root, prompt, paths, attemptId, phase }) {
  const suffix = phase ? `.${phase}` : "";
  const outputPath = path.join(paths.scratch, `${attemptId}${suffix}.worker-result.json`);
  const rawPath = path.join(paths.scratch, `${attemptId}${suffix}.worker-events.jsonl`);
  const command = buildRuntimeCommand({
    runtime,
    root,
    prompt,
    model: route.model,
    effort: route.effort,
    schemaPath: WORKER_SCHEMA_PATH,
    outputPath,
    schema: readJson(WORKER_SCHEMA_PATH),
    externalSandbox: runtime === "codex" && isNestedCodexSandbox(process.env),
  });
  return {
    command,
    outputPath,
    rawPath,
    label: `${phase || "slice"} worker ${attemptId}`,
  };
}

function runWorkerPhase(runtime, phase) {
  const run = runCommand(
    phase.command,
    phase.rawPath,
    Number(process.env.PAIR_TASK_TIMEOUT_MS || 60 * 60 * 1000),
    phase.label || "task worker",
  );
  const error =
    (run.status ?? 1) !== 0 || !(run.stdout || "").trim()
      ? runtimeDiagnostic(run)
      : "";
  const worker = parseWorkerResult(runtime, run.stdout || "", phase.outputPath);
  return {
    run,
    error,
    worker,
    usage: parseRuntimeUsage(runtime, run.stdout || ""),
  };
}

function runOne(root, runtime, options, paths) {
  const plan = fs.readFileSync(paths.plan, "utf8");
  const task = nextOpenTask(plan);
  if (!task) return { done: true };
  let linkage;
  try {
    linkage = readWorkLinkage(root, plan);
  } catch (error) {
    fail(error.message);
  }
  const ledger = readLedger(paths.ledger);
  const repoId = repositoryId(root);
  if (!options.legacyV3 && linkage.workId && Number.isFinite(options.maxWorkAttempts)) {
    const maxWorkAttempts = options.maxWorkAttempts;
    const workCap = workAttemptCapStatus(
      ledger,
      repoId,
      linkage.workId,
      maxWorkAttempts,
    );
    if (workCap.overCap) {
      fail(
        `Work ${linkage.workId} reached its ${maxWorkAttempts}-attempt safety cap across plan revisions; inspect the ledger before explicitly raising --max-work-attempts`,
      );
    }
  }
  const prior = taskHistory(ledger, task.id, repoId, linkage.workId, linkage.planDigest);
  const cap = attemptCapStatus(prior, options.maxAttempts);
  if (options.legacyV3 && cap.unstable)
    fail(
      `task ${task.id} was interrupted ${cap.trailingInterrupts} times without completing; the runtime environment looks unstable — resolve it before rerunning`,
    );
  if (Number.isFinite(options.maxAttempts) && cap.overCap)
    fail(
      options.legacyV3
        ? `task ${task.id} reached the ${options.maxAttempts}-attempt safety cap`
        : `task ${task.id} reached the explicitly configured ${options.maxAttempts}-attempt limit; inspect repository-local evidence before raising --max-attempts`,
    );
  const route = chooseRoute(task, runtime, ledger, options, repoId, linkage.workId, linkage.planDigest);
  // HITL: pause for human approval of proposed tests BEFORE opening an attempt.
  const gate = hitlGate({ root, plan, task, runtime, route, paths, options });
  if (gate.action === "await") return { done: false, awaitingApproval: true };
  const baselineCommit = git(root, ["rev-parse", "HEAD"]).stdout.trim();
  const baseline = git(root, ["rev-parse", "HEAD^{tree}"]).stdout.trim();
  const inline = options.legacyV3
    ? options.inline === true && !isDelegable(task)
    : true;
  const attempt = createAttempt({
    task,
    route: inline
      ? {
          id: "inline-coordinator",
          runtime: "inline",
          model: "coordinator",
          effort: "default",
          strength: 4,
        }
      : route,
    policyVersion: POLICY_VERSION,
    baseline,
    ...linkage,
  });
  attempt.baselineCommit = baselineCommit;
  attempt.repositoryId = repoId;
  attempt.root = root;
  attempt.phase = "implementing";
  attempt.role = "coordinator";
  attempt.sessionId = process.env.CODEX_THREAD_ID || process.env.CLAUDE_SESSION_ID || null;
  if (!options.dryRun) activateTask(paths.plan, task);
  let snapshot;
  try {
    snapshot = snapshotWorktree(root, paths.scratch);
  } catch (error) {
    fail(`cannot open task ${task.id}: ${error.message}`);
  }
  attempt.snapshotCommit = snapshot.commit || baselineCommit;

  if (inline) {
    // Hand the task to the coordinator session: open the attempt, print the brief,
    // and exit. `pair-loop --complete` closes it through the same evidence pipeline.
    attempt.mode = !options.legacyV3 && task.tddMode !== "red-contract"
      ? "inline"
      : task.tddMode === "cycle"
      ? "inline-red"
      : task.tddMode === "red-contract"
        ? "inline-red-contract"
        : "inline";
    attempt.snapshot = snapshot;
    if (options.dryRun) {
      console.log(JSON.stringify({ attempt }, null, 2));
      return { done: false, dryRun: true };
    }
    writePrivateJson(paths.active, attempt);
    appendJsonLine(paths.ledger, { event: "attempt.started", ...attempt });
    console.log(
      `pair-loop: task ${task.id} | inline coordinator | risk=${task.risk} complexity=${task.complexity}`,
    );
    console.log(
      inlineBrief(
        task,
        paths.plan,
        readJson(path.join(root, ".pair", "review.json")),
        gate.approvedTests,
        !options.legacyV3 && task.tddMode !== "red-contract"
          ? "slice"
          : ["cycle", "red-contract"].includes(task.tddMode)
            ? "red"
            : "green",
      ),
    );
    return { done: false, inlineHandoff: true };
  }

  const priorReview = readJson(path.join(root, ".pair", "review.json"));
  const needsRed = options.legacyV3 && ["cycle", "red-contract"].includes(task.tddMode);
  const redInvocation = needsRed
    ? buildWorkerPhase({
        runtime,
        route,
        root,
        prompt: redWorkerPrompt(task, paths.plan, gate.approvedTests, priorReview),
        paths,
        attemptId: attempt.attemptId,
        phase: "red",
      })
    : null;
  const singleRedContract = !options.legacyV3 && task.tddMode === "red-contract";
  const greenInvocation = options.legacyV3 && task.tddMode === "red-contract"
    ? null
    : buildWorkerPhase({
        runtime,
        route,
        root,
        prompt: singleRedContract
          ? redWorkerPrompt(task, paths.plan, gate.approvedTests, priorReview)
          : workerPrompt(
              task,
              paths.plan,
              priorReview,
              gate.approvedTests,
              !options.legacyV3,
            ),
        paths,
        attemptId: attempt.attemptId,
        phase: options.legacyV3 && task.tddMode === "cycle" ? "green" : null,
      });

  console.log(
    `pair-loop: task ${task.id} | ${runtime} ${route.model}/${route.effort} | risk=${task.risk} complexity=${task.complexity}`,
  );
  if (options.dryRun) {
    console.log(JSON.stringify(
      options.legacyV3
        ? {
            attempt,
            redCommand: redInvocation?.command || null,
            greenCommand: greenInvocation?.command || null,
          }
        : {
            attempt,
            workerCommand: greenInvocation?.command || null,
          },
      null,
      2,
    ));
    return { done: false, dryRun: true };
  }

  writePrivateJson(paths.active, attempt);
  appendJsonLine(paths.ledger, { event: "attempt.started", ...attempt });

  let redPhase = null;
  let greenSnapshot = null;
  if (redInvocation) {
    const red = runWorkerPhase(runtime, redInvocation);
    if (red.error) {
      console.error(
        `pair-loop: task ${task.id} RED worker runtime failed — ${red.error.split("\n")[0].slice(0, 300)} (see ${redInvocation.rawPath}.stderr)`,
      );
    }
    const redVerification = red.run.status === 0 && red.worker.status === "completed"
      ? verifyRed(root, task, snapshot)
      : { status: "fail", command: task.redVerify, output: red.worker.blocker || red.error || "RED worker did not complete" };
    redPhase = {
      worker: red.worker,
      run: red.run,
      usage: red.usage,
      verification: redVerification,
    };
    if (red.run.status !== 0 || red.worker.status !== "completed" || redVerification.status !== "pass") {
      const worker = red.worker.status === "completed"
        ? {
            ...red.worker,
            status: "blocked",
            blocker: `verification-defect: ${redVerification.output}`,
          }
        : red.worker;
      return assessAttempt({
        root,
        runtime,
        options,
        paths,
        task,
        attempt,
        prior,
        snapshot,
        route,
        worker,
        workerRun: red.run,
        workerError: red.error,
        redPhase,
      });
    }
    if (task.tddMode === "red-contract") {
      return assessAttempt({
        root,
        runtime,
        options,
        paths,
        task,
        attempt,
        prior,
        snapshot,
        route,
        worker: red.worker,
        workerRun: red.run,
        workerError: red.error,
        redPhase,
      });
    }
    greenSnapshot = snapshotWorktree(root, paths.scratch);
    console.log(`pair-loop: task ${task.id} RED contract reproduced; starting GREEN`);
  }

  const green = runWorkerPhase(runtime, greenInvocation);
  if (green.error) {
    console.error(
      `pair-loop: task ${task.id} GREEN worker runtime failed — ${green.error.split("\n")[0].slice(0, 300)} (see ${greenInvocation.rawPath}.stderr)`,
    );
  }
  let singleSessionRedPhase = null;
  if (singleRedContract) {
    const redVerification = green.run.status === 0 && green.worker.status === "completed"
      ? verifyRed(root, task, snapshot)
      : {
          status: "fail",
          command: task.redVerify,
          output: green.worker.blocker || green.error || "RED worker did not complete",
        };
    singleSessionRedPhase = {
      worker: green.worker,
      run: green.run,
      usage: green.usage,
      verification: redVerification,
    };
  }
  return assessAttempt({
    root,
    runtime,
    options,
    paths,
    task,
    attempt,
    prior,
    snapshot,
    route,
    worker: green.worker,
    workerRun: green.run,
    workerError: green.error,
    redPhase: singleSessionRedPhase || redPhase,
    greenSnapshot,
  });
}

function coordinatorSessionId() {
  return process.env.CODEX_THREAD_ID ||
    process.env.CLAUDE_SESSION_ID ||
    process.env.CLAUDE_SESSION_ID_OVERRIDE ||
    null;
}

function discardActiveAttempt(root, options) {
  const activeFile = path.join(root, ".pair", "active-attempt.json");
  const planFile = path.join(root, ".pair", "plan.md");
  const active = readJson(activeFile);
  if (!active?.attemptId) throw new Error("no active attempt is available to discard");
  const task = parsePlan(fs.readFileSync(planFile, "utf8"))
    .tasks.find(candidate => candidate.id === active.taskId);
  if (!task) throw new Error(`active task ${active.taskId} no longer exists in the plan`);
  const changed = changedPathsSinceSnapshot(root, active.snapshot)
    .filter(file => !isPairRuntimeArtifact(file));
  if (!options.confirmDiscard) {
    console.log([
      `Pair v4 discard preview for attempt ${active.attemptId}:`,
      ...(changed.length > 0 ? changed.map(file => `- ${file}`) : ["- No repository paths changed."]),
      "",
      `No files were changed. To explicitly discard this exact attempt, run: pair-loop --discard-attempt ${active.attemptId} --confirm-discard`,
    ].join("\n"));
    return { preview: true, attemptId: active.attemptId, changed };
  }
  if (options.controlValue !== active.attemptId) {
    throw new Error(`--confirm-discard requires the exact active attempt ID ${active.attemptId}`);
  }
  const attemptDirectory = path.join(
    pairStatePaths(root, active.workId || null).attempts,
    active.attemptId,
  );
  fs.mkdirSync(attemptDirectory, { recursive: true, mode: 0o700 });
  const completePatch = path.join(attemptDirectory, "discarded-complete.patch");
  writeReviewSlicePatch(root, task, active.snapshot, completePatch);
  try {
    revertToSnapshot(
      root,
      active.snapshot,
      path.join(attemptDirectory, "discarded-tracked.patch"),
    );
  } catch (error) {
    const marker = recordRestorationFailure(root, task, active, error);
    throw new Error(
      `explicit discard could not restore the pre-attempt state: ${marker.reason}; inspect ${restorationFailurePath(root)}`,
    );
  }
  queueTask(planFile, task);
  fs.rmSync(activeFile, { force: true });
  cleanupWorktreeSnapshots(active.snapshot, active.greenSnapshot || null);
  appendPairEvent(root, {
    event: "attempt.outcome",
    workId: active.workId || null,
    attemptId: active.attemptId,
    taskId: active.taskId,
    planDigest: active.planDigest || null,
    disposition: "discarded",
    action: "explicit-discard",
    cause: "human-confirmed-discard",
    terminal: true,
    affected_paths: changed,
    recovery_patch: path.relative(root, completePatch).split(path.sep).join("/"),
  });
  console.log(
    `pair-v4: explicitly discarded attempt ${active.attemptId}; restored ${changed.length} path(s) and preserved its complete patch at ${path.relative(root, completePatch)}`,
  );
  return { discarded: true, attemptId: active.attemptId, changed, completePatch };
}

function runControl(root, options) {
  const control = options.control;
  if (control === "host") {
    const state = ensureHost(root);
    console.log(options.json ? JSON.stringify(state, null, 2) : `pair-v4: host ${state.session} ready (editor ${state.panes.editor}, coordinator ${state.panes.coordinator}, reviewer ${state.panes.reviewer})`);
    return;
  }
  if (control === "attach") {
    const state = ensureHost(root);
    const args = process.env.TMUX
      ? ["switch-client", "-t", `=${state.session}`]
      : ["attach-session", "-t", `=${state.session}`];
    const attached = childProcess.spawnSync("tmux", args, { stdio: "inherit" });
    if (attached.status !== 0) fail(`could not attach tmux host ${state.session}`);
    return;
  }
  if (control === "status") {
    const state = loadPairState(root);
    const freshness = freshnessProjection(root);
    const host = hostStatus(root, { freshness });
    if (options.json) {
      console.log(JSON.stringify({ state, freshness, host }, null, 2));
    } else {
      const active = state.active;
      console.log([
        `Pair v4 ${state.lifecycle}`,
        `Work: ${state.work_id || "none"}`,
        `Task: ${active?.task_id || "none"}`,
        `Attempt: ${active?.attempt_id || "none"}`,
        `Phase: ${active?.phase || state.continuation.resume_target || "none"}`,
        `Coordinator owner: ${state.continuation.owner_session_id || "unclaimed"}`,
        `Review Session: ${active?.reviewer_session_id || readReviewSession(root)?.session_id || "none"}`,
        `Host: ${host.exists ? `${host.session} (${host.panes.length} panes)` : "not started"}`,
        `Freshness Gate: ${freshness.warning || "no registered Agent Conversation requires a handover"}`,
      ].join("\n"));
    }
    return;
  }
  if (control === "pause") {
    const state = pauseWork(root);
    console.log(state.continuation.paused
      ? `pair-v4: paused at ${state.continuation.resume_target || "ready"}; implementation and evidence are preserved`
      : `pair-v4: pause requested; request ${state.in_flight_request?.request_id || "in flight"} will finish its current boundary, then Work pauses at ${state.in_flight_request?.phase || state.continuation.resume_target || "ready"}`);
    return;
  }
  if (control === "resume") {
    const state = resumeWork(root, coordinatorSessionId(), options.runtime === "auto" ? null : options.runtime);
    console.log(`pair-v4: resumed ${state.active?.attempt_id || state.work_id || "Work"} at ${state.lifecycle}`);
    return;
  }
  if (control === "takeover") {
    const state = takeoverWork(
      root,
      options.controlValue || coordinatorSessionId(),
      options.runtime === "auto" ? null : options.runtime,
    );
    console.log(`pair-v4: continuation ownership transferred to ${state.continuation.owner_session_id}`);
    return;
  }
  if (control === "cancel-now") {
    const result = cancelInFlight(root);
    console.log(result.cancelled
      ? `pair-v4: cancelled request ${result.pid}; resume target remains ${result.state.continuation.resume_target}`
      : "pair-v4: no in-flight request; saved phase is unchanged");
    return;
  }
  if (control === "discard-attempt") {
    discardActiveAttempt(root, options);
    return;
  }
  if (control === "begin-human-edit") {
    const state = beginHumanEdit(root, options.controlValue);
    console.log(`pair-v4: human ${state.continuation.human_edit.kind} edit has exclusive control; end it with --end-human-edit`);
    return;
  }
  if (control === "end-human-edit") {
    const state = endHumanEdit(root);
    console.log(`pair-v4: human edit recorded; resume target is ${state.continuation.resume_target}`);
    return;
  }
  if (control === "steer") {
    if (!String(options.controlValue || "").trim()) fail("--steer requires a message");
    const pane = sendKeys(root, "coordinator", options.controlValue);
    console.log(`pair-v4: steering delivered to visible coordinator pane ${pane}`);
    return;
  }
  fail(`unsupported control ${control}`);
}

function main() {
  const options = parseArgs(process.argv.slice(2));
  if (options.help) {
    console.log(
      "Usage: pair-task [--runtime codex|claude|auto] [--fresh-from HANDOVER_ID|--adopt-handover HANDOVER_ID|--allow-cold-resume HANDOVER_ID --once --confirm-cost-risk] [--host|--attach|--status [--json]|--pause|--resume|--takeover [SESSION]|--cancel-now|--discard-attempt [ATTEMPT] [--confirm-discard]|--begin-human-edit plan|code|--end-human-edit|--steer MESSAGE] [--allow-cross-runtime-fallback] [--model MODEL] [--effort LEVEL] [--once] [--inline] [--complete] [--doctor] [--dry-run] [--no-independent-review] [--advisory-review] [--hitl] [--approve-tests all|1,3|none] [--max-attempts N] [--max-work-attempts N] [--max-final-reviews N] [--legacy-v3]",
    );
    return;
  }
  const root = gitRoot();
  const handoverCommands = [options.freshFrom, options.adoptHandover, options.allowColdResume].filter(Boolean);
  if (handoverCommands.length > 1) fail("choose exactly one Agent Conversation Handover command");
  if (options.freshFrom) {
    try {
      const launched = launchFreshAgentConversation(root, {
        handoverId: options.freshFrom,
        runtime: options.runtime,
      });
      console.log(`pair-loop: launched fresh ${launched.runtime} Agent Conversation for ${launched.handoverId}`);
    } catch (error) {
      fail(error.message);
    }
    return;
  }
  if (options.adoptHandover || options.allowColdResume) {
    const agentConversationId = coordinatorSessionId();
    if (!agentConversationId) fail("Agent Conversation adoption requires a native conversation identity");
    let handoverRuntime;
    try {
      handoverRuntime = resolveRuntime(options.runtime);
      if (options.adoptHandover) {
        const adopted = adoptFreshAgentConversation(root, {
          handoverId: options.adoptHandover,
          runtime: handoverRuntime,
          agentConversationId,
        });
        takeoverWork(root, agentConversationId, handoverRuntime);
        console.log(`pair-loop: adopted Agent Conversation Handover ${adopted.handoverId}`);
      } else {
        const authorized = authorizeOneShotColdResume(root, {
          handoverId: options.allowColdResume,
          runtime: handoverRuntime,
          agentConversationId,
          once: options.once,
          confirmCostRisk: options.confirmCostRisk,
        });
        console.log(`pair-loop: one cold-cost turn authorized for ${authorized.handoverId}`);
      }
    } catch (error) {
      fail(error.message);
    }
    return;
  }
  if (options.control) {
    try {
      runControl(root, options);
    } catch (error) {
      fail(error.message);
    }
    if (options.control !== "resume") return;
    options.control = null;
  }
  if (options.doctor) process.exit(runDoctor(root, options) > 0 ? 1 : 0);
  if (options.approveTests !== undefined) {
    const proposal = readJson(testProposalPath(root));
    if (!proposal?.tests) fail("no test proposal is awaiting approval");
    let approved;
    try {
      approved = applyTestApproval(proposal, options.approveTests);
    } catch (error) {
      fail(error.message);
    }
    writeTestProposal(root, approved);
    const kept = approved.tests.filter((test) => test.approved).length;
    console.log(
      `pair-loop: approved ${kept}/${approved.tests.length} proposed test(s) for task ${approved.taskId}${
        kept === 0
          ? " — none approved; revise the plan task or delete .pair/test-proposal.json to repropose"
          : "; rerun pair-loop to write them"
      }`,
    );
    return;
  }
  let runtime;
  try {
    runtime = resolveRuntime(options.runtime, {
      allowCrossRuntimeFallback: options.allowCrossRuntimeFallback,
    });
  } catch (error) {
    fail(error.message);
  }
  const pairPlan = path.join(root, ".pair", "plan.md");
  const loopPlan = path.join(root, ".claude-loop.md");
  const plan = fs.existsSync(pairPlan) ? pairPlan : loopPlan;
  if (!fs.existsSync(plan))
    fail("no .pair/plan.md or .claude-loop.md; create a plan first");
  const validator = path.join(SCRIPT_DIR, "validate-plan");
  if (plan === pairPlan && process.env.PAIR_SKIP_PLAN_VALIDATION !== "1") {
    if (!fs.existsSync(validator))
      fail(`canonical plan validator is missing: ${validator}`);
    const validation = childProcess.spawnSync(
      process.execPath,
      [validator, plan],
      { cwd: root, encoding: "utf8" },
    );
    if (validation.status !== 0)
      fail(
        (
          validation.stdout ||
          validation.stderr ||
          "plan validation failed"
        ).trim(),
      );
  }
  let canonicalLinkage = null;
  if (plan === pairPlan) {
    try {
      canonicalLinkage = ensurePairPlanApproval(
        root,
        fs.readFileSync(plan, "utf8"),
        options,
      );
    } catch (error) {
      fail(error.message);
    }
  }
  const existingBinding = !process.env.PAIR_DATA_DIR && canonicalLinkage?.workId
    ? readJson(path.join(root, ".pair", "ledger-bindings.json"))
      ?.bindings?.[`work:${canonicalLinkage.workId}`]
    : null;
  const configuredLegacyLedger = process.env.PAIR_DATA_DIR
    ? path.join(process.env.PAIR_DATA_DIR, "attempts.jsonl")
    : existingBinding?.legacy_ledger ||
      (existingBinding?.ledger && !String(existingBinding.ledger).startsWith(".pair/")
        ? existingBinding.ledger
        : path.join(os.homedir(), ".local", "share", "pair-v3", "attempts.jsonl"));
  const scratchBase =
    process.env.CLAUDE_SCRATCH_DIR ||
    process.env.PAIR_SCRATCH_DIR ||
    path.join(os.homedir(), ".claude-scratch");
  const scratch = path.join(scratchBase, path.basename(root), "pair-v4");
  fs.mkdirSync(scratch, { recursive: true, mode: 0o700 });
  fs.mkdirSync(path.join(root, ".pair"), { recursive: true });
  const repositoryState = pairStatePaths(root, canonicalLinkage?.workId || null);
  const paths = {
    plan,
    active: path.join(root, ".pair", "active-attempt.json"),
    ledger: repositoryState.events,
    legacyLedger: configuredLegacyLedger,
    scratch,
  };
  const restorationFailure = readJson(restorationFailurePath(root));
  if (restorationFailure) {
    fail(
      `restoration failure is unresolved: ${restorationFailure.reason || "worktree state is untrusted"}${
        restorationFailure.remaining_paths?.length
          ? ` (${restorationFailure.remaining_paths.join(", ")})`
          : ""
      }; inspect or remove ${restorationFailurePath(root)} only after restoring the worktree`,
    );
  }
  if (!options.dryRun) {
    try {
      bindAttemptLedger(
        root,
        paths.legacyLedger,
        canonicalLinkage?.workId || null,
        plan,
      );
    } catch (error) {
      fail(error.message);
    }
  }
  let activeLoop = null;
  if (!options.dryRun) {
    try {
      activeLoop = beginActivePairLoop(root, plan);
    } catch (error) {
      fail(error.message);
    }
  }
  const cleanupActiveLoop = () => endActivePairLoop(root, activeLoop);
  if (activeLoop) process.once("exit", cleanupActiveLoop);
  try {
    if (!options.dryRun) {
      appendPairEvent(root, {
        event: "work.opened",
        workId: canonicalLinkage?.workId || null,
        planDigest: canonicalLinkage?.planDigest || planContractDigest(fs.readFileSync(plan, "utf8")),
        phase: loadPairState(root).active?.phase || "ready",
      });
      const persisted = loadPairState(root);
      if (persisted.continuation.human_edit) {
        fail(`human ${persisted.continuation.human_edit.kind} edit has exclusive control; finish it with --end-human-edit`);
      }
      if (persisted.continuation.paused) {
        fail(`Work is paused at ${persisted.continuation.resume_target || "ready"}; use --resume before dispatch`);
      }
      if (coordinatorSessionId()) {
        appendPairEvent(root, {
          event: "continuation.claimed",
          workId: canonicalLinkage?.workId || null,
          attemptId: persisted.active?.attempt_id || null,
          session_id: coordinatorSessionId(),
          runtime,
        });
        registerAgentConversation(root, {
          runtime,
          agentConversationId: coordinatorSessionId(),
          kind: "pair",
        });
        updateAgentConversationCheckpoint(root, {
          runtime,
          agentConversationId: coordinatorSessionId(),
          kind: "pair",
          checkpoint: derivePairCheckpoint(root),
        });
      }
      const inFlight = liveInFlightRequest(loadPairState(root));
      if (inFlight) {
        console.log(
          `pair-v4: ${inFlight.request_kind || "request"} ${inFlight.request_id || "in flight"} is still running; preserving its ${inFlight.phase || "saved"} phase`,
        );
        return;
      }
    }
    if (options.complete) {
      inlineComplete(root, runtime, options, paths);
      if (!nextOpenTask(fs.readFileSync(plan, "utf8"))) {
        finalizePairPlan(root, runtime, options, paths);
        console.log("pair-loop: all plan tasks complete");
      }
      return;
    }
    recoverActiveAttempt(paths);
    if (!options.legacyV3 && fs.existsSync(paths.active)) {
      const resumed = resumeActiveAttempt(root, runtime, options, paths);
      if (resumed?.action === "complete-task") {
        if (nextOpenTask(fs.readFileSync(plan, "utf8"))) {
          runOne(root, runtime, options, paths);
        } else {
          finalizePairPlan(root, runtime, options, paths);
          console.log("pair-v4: all plan tasks complete");
        }
      }
      return;
    }
    if (options.legacyV3) reconcileOrphanedAttempts(paths, root);
    while (true) {
      const result = runOne(root, runtime, options, paths);
      if (result.awaitingApproval) {
        console.log(
          "pair-loop: paused — a test proposal is awaiting your approval",
        );
        break;
      }
      if (result.inlineHandoff) break;
      if (result.done || result.dryRun || options.once) break;
    }
    if (!nextOpenTask(fs.readFileSync(plan, "utf8"))) {
      finalizePairPlan(root, runtime, options, paths);
      console.log("pair-loop: all plan tasks complete");
    }
  } finally {
    if (activeLoop) {
      process.removeListener("exit", cleanupActiveLoop);
      cleanupActiveLoop();
    }
  }
}

if (require.main === module) main();

