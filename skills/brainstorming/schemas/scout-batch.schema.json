{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nhat-dev-toolkit.local/schemas/scout-batch.schema.json",
  "title": "Bounded evidence scout batch result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "type",
    "work_id",
    "runtime",
    "model",
    "effort",
    "packets",
    "calls",
    "deferred_review_slice_ids",
    "evidence_by_key",
    "unknowns"
  ],
  "properties": {
    "version": { "const": 1 },
    "type": { "const": "evidence.scout-batch" },
    "work_id": { "type": "string", "minLength": 1, "maxLength": 200 },
    "runtime": { "enum": ["codex", "claude"] },
    "model": { "type": "string", "minLength": 1, "maxLength": 100 },
    "effort": { "const": "low" },
    "packets": {
      "type": "array",
      "maxItems": 6,
      "items": { "$ref": "#/$defs/packet" }
    },
    "calls": {
      "type": "array",
      "maxItems": 6,
      "items": { "$ref": "#/$defs/call" }
    },
    "deferred_review_slice_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 120 }
    },
    "evidence_by_key": {
      "type": "object",
      "propertyNames": { "minLength": 1, "maxLength": 200 },
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": { "$ref": "#/$defs/evidence" }
      }
    },
    "unknowns": {
      "type": "array",
      "items": { "$ref": "#/$defs/unknown" }
    }
  },
  "$defs": {
    "shortlist": {
      "type": "object",
      "additionalProperties": false,
      "required": ["public_symbols", "boundary_crossings", "tests", "unknowns"],
      "properties": {
        "public_symbols": { "$ref": "#/$defs/textList" },
        "boundary_crossings": { "$ref": "#/$defs/textList" },
        "tests": { "$ref": "#/$defs/textList" },
        "unknowns": { "$ref": "#/$defs/textList" }
      }
    },
    "oversizedReviewSlice": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_slice_id",
        "original_changed_file_count",
        "original_changed_line_count",
        "shortlist"
      ],
      "properties": {
        "review_slice_id": { "type": "string", "minLength": 1, "maxLength": 120 },
        "original_changed_file_count": { "type": "integer", "minimum": 0 },
        "original_changed_line_count": { "type": "integer", "minimum": 0 },
        "shortlist": { "$ref": "#/$defs/shortlist" }
      }
    },
    "packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_digest",
        "review_slice_ids",
        "changed_file_count",
        "changed_line_count",
        "brief_bytes",
        "packet_bytes",
        "oversized_review_slices"
      ],
      "properties": {
        "packet_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "review_slice_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 120 }
        },
        "changed_file_count": { "type": "integer", "minimum": 0, "maximum": 40 },
        "changed_line_count": { "type": "integer", "minimum": 0, "maximum": 1200 },
        "brief_bytes": { "type": "integer", "minimum": 1, "maximum": 4000 },
        "packet_bytes": { "type": "integer", "minimum": 1, "maximum": 6000 },
        "oversized_review_slices": {
          "type": "array",
          "maxItems": 1,
          "items": { "$ref": "#/$defs/oversizedReviewSlice" }
        }
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_tokens", "cached_input_tokens", "output_tokens", "reasoning_output_tokens"],
      "properties": {
        "input_tokens": { "type": "integer", "minimum": 0 },
        "cached_input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "reasoning_output_tokens": { "type": "integer", "minimum": 0 }
      }
    },
    "call": {
      "type": "object",
      "additionalProperties": false,
      "required": ["call_id", "packet_digest", "wave", "status", "usage"],
      "properties": {
        "call_id": { "type": "string", "pattern": "^scout-[0-9]{3}$" },
        "packet_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "wave": { "type": "integer", "minimum": 1, "maximum": 2 },
        "status": { "enum": ["succeeded", "failed", "timed_out"] },
        "error": { "type": "string", "minLength": 1, "maxLength": 500 },
        "usage": { "$ref": "#/$defs/usage" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "succeeded" } } },
          "then": { "not": { "required": ["error"] } },
          "else": { "required": ["error"] }
        }
      ]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_key",
        "kind",
        "path",
        "startLine",
        "endLine",
        "observation",
        "packet_digest",
        "review_slice_ids"
      ],
      "properties": {
        "evidence_key": { "type": "string", "minLength": 1, "maxLength": 200 },
        "kind": { "enum": ["symbol", "caller", "dependency", "framework", "test", "configuration"] },
        "path": { "type": "string", "minLength": 1, "maxLength": 300 },
        "startLine": { "type": "integer", "minimum": 1 },
        "endLine": { "type": "integer", "minimum": 1 },
        "observation": { "type": "string", "minLength": 1, "maxLength": 400 },
        "packet_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "review_slice_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": { "type": "string", "minLength": 1, "maxLength": 120 }
        }
      }
    },
    "unknown": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "packet_digest", "review_slice_ids"],
      "properties": {
        "text": { "type": "string", "minLength": 1, "maxLength": 300 },
        "packet_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "review_slice_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": { "type": "string", "minLength": 1, "maxLength": 120 }
        }
      }
    },
    "textList": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 300 }
    }
  }
}
