{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.local/share/my-claude-code/hooks/commit-guard.sh",
            "if": "Bash(*git commit*)",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.local/share/my-claude-code/hooks/scratch-guard.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.local/share/my-claude-code/hooks/gate-orient.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.local/share/my-claude-code/hooks/await-notify.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "PAIR_HOOK_RUNTIME=claude bash ~/.local/share/my-claude-code/hooks/pair-owner.sh",
            "if": "Bash(*pair-*)",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.local/share/my-claude-code/hooks/delegation-nudge.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "PAIR_HOOK_RUNTIME=claude bash ~/.local/share/my-claude-code/hooks/stop-gate.sh",
            "timeout": 180
          }
        ]
      }
    ]
  }
}
