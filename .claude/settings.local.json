{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(tail:*)",
      "Bash(ls:*)",
      "Bash(make validate-sync:*)",
      "mcp__ide__getDiagnostics",
      "Bash(npm run:*)",
      "Bash(node:*)",
      "WebFetch(domain:developers.openai.com)",
      "mcp__aspire__list_resources",
      "WebFetch(domain:aspire.dev)",
      "Bash(echo:*)",
      "Bash(aspire-logs:*)",
      "Bash(for cmd:*)",
      "Bash(bash /Users/nhat.tran/.local/share/my-claude-code/install.sh 2>&1 | grep -E \"CLI|verification|Environment|OK|FAILED|PATH|kubectl|Aspire|complete\")",
      "WebFetch(domain:www.elastic.co)",
      "Bash(jq -c \"select\\(.type == \"\"user\"\"\\) | {msg: \\(.message.content // .message | tostring\\)[0:200]}\")",
      "Bash(jq -r \"select\\(.type == \"\"assistant\"\"\\) | .message.content | if type == \"\"array\"\" then [.[] | select\\(.type == \"\"text\"\"\\) | .text] | join\\(\"\"\\\\n\"\"\\) else . end\")",
      "Bash(jq -r \":*)",
      "Bash(jq -r \"select\\(.type == \"\"progress\"\"\\) | .content[0:200]\")",
      "Bash(jq:*)",
      "Bash(find /Users/nhat.tran/.local/share/my-claude-code -name *observability* -o -name *playbook*)",
      "Bash(git:*)",
      "Read(//Users/nhat.tran/.claude/**)",
      "Bash(find /Users/nhat.tran/.local/share/my-claude-code/skills/pair-* -type f -name \"*.md\")",
      "Bash(aspire:*)",
      "Bash(python3:*)",
      "Read(//Users/nhat.tran/Work/worktrees/Regrinding/AI/workAi/**)",
      "Bash(dotnet run:*)",
      "Bash(dotnet tool:*)",
      "Bash(dotnet script:*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/.secrets/**)",
      "Read(**/secret/**)",
      "Read(**/appsettings.*.json)",
      "Read(**/usersecrets/**)",
      "Read(**/.user.secrets)",
      "Read(**/secrets.json)",
      "Read(**/local.settings.json)",
      "Read(**/ConnectionStrings.config)",
      "Read(**/web.config)",
      "Read(**/Web.config)",
      "Read(**/nuget.config)",
      "Read(**/NuGet.Config)",
      "Read(**/application.properties)",
      "Read(**/application.yml)",
      "Read(**/application.yaml)",
      "Read(**/application-*.*)",
      "Read(**/bootstrap.properties)",
      "Read(**/bootstrap.yml)",
      "Read(**/bootstrap.yaml)",
      "Read(**/.m2/settings.xml)",
      "Read(**/.gradle/gradle.properties)",
      "Read(**/gradle.properties)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.jks)",
      "Read(**/*.keystore)",
      "Read(**/*.truststore)",
      "Read(**/*.crt)",
      "Read(**/*.cer)",
      "Read(**/*credentials*)",
      "Read(**/*password*)",
      "Read(**/*secret*)",
      "Read(**/*apikey*)",
      "Read(**/*api_key*)",
      "Read(**/*token*)",
      "Read(**/.npmrc)",
      "Read(**/.yarnrc)",
      "Read(**/.yarnrc.yml)",
      "Read(**/.git-credentials)",
      "Read(**/.netrc)",
      "Read(**/.aws/**)",
      "Read(**/.azure/**)",
      "Read(**/.gcloud/**)",
      "Read(**/.kube/config)",
      "Read(**/.ssh/**)",
      "Read(**/.docker/config.json)",
      "Read(**/vault-config.*)",
      "Read(**/.vault-token)"
    ]
  },
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": false
  }
}
