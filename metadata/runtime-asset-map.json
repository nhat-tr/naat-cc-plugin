{
  "version": 2,
  "runtimes": {
    "claude": {
      "display_name": "Claude Code",
      "global_instruction_path": "~/.claude/CLAUDE.md",
      "agents_dir": "~/.claude/agents",
      "commands_dir": "~/.claude/commands",
      "contexts_dir": "~/.claude/contexts"
    },
    "codex": {
      "display_name": "Codex",
      "global_instruction_paths": [
        "~/.codex/AGENTS.md",
        "~/.agents/AGENTS.md"
      ],
      "skill_dirs": [
        "~/.codex/skills",
        "~/.agents/skills"
      ]
    },
    "copilot": {
      "display_name": "GitHub Copilot",
      "repo_instruction_path": ".github/copilot-instructions.md",
      "repo_instruction_dir": ".github/instructions",
      "repo_skills_dir": ".github/skills",
      "global_skill_dir": "~/.copilot/skills"
    }
  },
  "generated_outputs": {
    "repo_agents": {
      "template": "repo-agents",
      "output": "AGENTS.md"
    },
    "claude_global": {
      "template": "claude",
      "output": "CLAUDE.md"
    },
    "codex_global": {
      "template": "codex",
      "output": "generated/instructions/codex-global.md"
    },
    "copilot_repo": {
      "template": "copilot",
      "output": ".github/copilot-instructions.md"
    },
    "copilot_csharp": {
      "template": "copilot-csharp",
      "output": ".github/instructions/csharp.instructions.md"
    },
    "copilot_typescript": {
      "template": "copilot-typescript",
      "output": ".github/instructions/typescript.instructions.md"
    }
  },
  "assets": {
